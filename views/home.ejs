<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>LitMaster · English Study Hub</title>
    
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg: #fafbff;
            --card-bg: #ffffff;
            --text: #1e293b;
            --text-light: #475569;
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --accent: #f59e0b;
            --green: #10b981;
            --red: #ef4444;
            --shadow: 0 4px 20px rgba(0,0,0,0.05);
            --shadow-lg: 0 8px 32px rgba(0,0,0,0.08);
            --radius: 16px;
            --radius-sm: 12px;
            --radius-btn: 12px;
            --transition: 0.2s ease-in-out;
            --font: 'Inter', system-ui, -apple-system, sans-serif;
            --option-bg: #f1f5f9;
            --feedback-bg: #f1f5f9;
        }

        body.dark {
            --bg: #0f172a;
            --card-bg: #1e293b;
            --text: #f1f5f9;
            --text-light: #94a3b8;
            --primary: #818cf8;
            --primary-hover: #6366f1;
            --accent: #fbbf24;
            --green: #34d399;
            --red: #f87171;
            --shadow: 0 4px 20px rgba(0,0,0,0.3);
            --shadow-lg: 0 8px 32px rgba(0,0,0,0.5);
            --option-bg: #334155;
            --feedback-bg: #334155;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            transition: background 0.3s, color 0.3s;
            overflow-x: hidden;
            position: relative;
        }

        .bg-gradient {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1;
            background: linear-gradient(135deg, #ffedd5, #fef3c7, #dbeafe, #e0e7ff);
            background-size: 400% 400%;
            animation: gradientMove 20s ease infinite;
        }
        body.dark .bg-gradient {
            background: linear-gradient(135deg, #1e1b4b, #312e81, #1e293b, #0f172a);
            background-size: 400% 400%;
            animation: gradientMove 20s ease infinite;
        }
        @keyframes gradientMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

        .btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            background: var(--primary); color: #fff;
            font-weight: 600; font-size: 0.95rem; padding: 0.75rem 1.8rem;
            border: none; border-radius: var(--radius-btn); cursor: pointer;
            text-decoration: none; transition: all var(--transition);
            white-space: nowrap; box-shadow: 0 4px 12px rgba(99,102,241,0.3);
        }
        .btn:hover { background: var(--primary-hover); transform: translateY(-2px); box-shadow: 0 8px 20px rgba(99,102,241,0.4); }
        .btn:active { transform: scale(0.97); }
        .btn--outline { background: transparent; color: var(--primary); box-shadow: 0 0 0 2px var(--primary); }
        .btn--outline:hover { background: rgba(99,102,241,0.08); }
        .btn--sm { padding: 0.5rem 1.2rem; font-size: 0.85rem; }
        .btn--contact {
            background: var(--green); color: #fff;
            box-shadow: 0 4px 12px rgba(16,185,129,0.3);
        }
        .btn--contact:hover { background: #059669; }

        .header {
            position: sticky; top: 0; z-index: 100;
            background: rgba(255,255,255,0.85); backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0,0,0,0.04);
            padding: 0.8rem 0;
            transition: background 0.3s;
        }
        body.dark .header { background: rgba(15,23,42,0.85); border-color: rgba(255,255,255,0.05); }
        .header-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: nowrap; }
        .logo {
            font-weight: 800; font-size: 1.6rem; color: var(--primary);
            text-decoration: none; letter-spacing: -0.5px;
        }
        .nav { display: flex; align-items: center; gap: 1.2rem; font-weight: 500; }
        .nav a {
            color: var(--text-light); text-decoration: none; padding: 0.3rem 0;
            border-bottom: 2px solid transparent; transition: all var(--transition);
            white-space: nowrap;
        }
        .nav a:hover, .nav a.active { color: var(--primary); border-bottom-color: var(--primary); }
        .dark-toggle { background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--text); margin-left: 0.5rem; }

        .hero { padding: 3rem 0 2rem; text-align: center; }
        .hero h1 {
            font-size: clamp(2.4rem, 8vw, 4rem); font-weight: 800;
            background: linear-gradient(135deg, #6366f1, #a78bfa);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }
        .hero p { font-size: 1.15rem; color: var(--text-light); max-width: 550px; margin: 0 auto; }

        .live-clock {
            text-align: center;
            font-weight: 600;
            font-size: 1.3rem;
            margin-bottom: 1.5rem;
            color: var(--text-light);
        }
        .live-clock .time { font-size: 2.4rem; font-weight: 700; color: var(--primary); }
        .live-clock .date { font-size: 1rem; margin-top: 0.2rem; }
        .live-clock .highlight { font-size: 0.9rem; margin-top: 0.5rem; opacity: 0.7; }

        .section { padding: 2rem 0; }
        .card {
            background: var(--card-bg); border-radius: var(--radius);
            padding: 2rem; box-shadow: var(--shadow);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
        .card h3 { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.8rem; }

        .curiosity-card {
            border-left: 6px solid var(--primary);
            display: flex; align-items: center; gap: 1.2rem;
        }
        .curiosity-icon { font-size: 2.2rem; }
        .curiosity-text { font-weight: 600; color: var(--text); min-height: 2.5rem; font-size: 1.1rem; }
        .curiosity-source { font-size: 0.75rem; color: var(--text-light); margin-top: 0.3rem; }
        .curiosity-progress {
            height: 4px; background: var(--option-bg); border-radius: 4px;
            margin-top: 0.6rem; overflow: hidden;
        }
        .curiosity-progress-fill { height: 100%; background: var(--primary); width: 0%; transition: width 0.1s; }

        .quiz-card { max-width: 800px; margin: 0 auto; }
        .quiz-progress { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; font-weight: 600; color: var(--text-light); flex-wrap: wrap; gap: 0.5rem; }
        .badge {
            background: #ede9fe; color: var(--primary); padding: 0.25rem 0.8rem; border-radius: 20px;
            font-size: 0.8rem; font-weight: 700;
        }
        .xp-badge { background: #dbeafe; color: #2563eb; }
        body.dark .badge { background: #312e81; color: #a5b4fc; }
        body.dark .xp-badge { background: #1e3a5f; color: #93c5fd; }
        .progress-bar { width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; margin: 0.8rem 0 1.2rem; overflow: hidden; }
        body.dark .progress-bar { background: #334155; }
        .progress-fill { height: 100%; background: var(--primary); border-radius: 10px; transition: width 0.3s; }
        .question-text { font-size: 1.3rem; font-weight: 700; margin-bottom: 1.2rem; }
        .options { display: flex; flex-direction: column; gap: 0.7rem; margin-bottom: 1rem; }
        .option {
            display: flex; align-items: center; gap: 0.8rem; padding: 1rem 1.2rem;
            background: var(--option-bg); border-radius: var(--radius-sm);
            border: 2px solid transparent;
            cursor: pointer; transition: all var(--transition); font-size: 1rem; user-select: none;
        }
        .option:hover:not(.disabled) { border-color: var(--primary); background: var(--card-bg); }
        .option input[type="radio"] { display: none; }
        .option .circle {
            width: 20px; height: 20px; border-radius: 50%; border: 2px solid #cbd5e1;
            display: flex; align-items: center; justify-content: center; transition: 0.2s;
        }
        body.dark .option .circle { border-color: #64748b; }
        .option.selected .circle { border-color: var(--primary); background: var(--primary); }
        .option.selected .circle::after { content: ''; width: 8px; height: 8px; background: #fff; border-radius: 50%; }
        .option label { flex: 1; font-weight: 500; cursor: pointer; color: var(--text); }
        .option.correct { background: #d1fae5; border-color: var(--green); }
        .option.wrong { background: #fee2e2; border-color: var(--red); }
        body.dark .option.correct { background: #064e3b; }
        body.dark .option.wrong { background: #7f1d1d; }
        .option.disabled { pointer-events: none; opacity: 0.7; }
        .quiz-actions { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.8rem; margin-top: 0.8rem; }
        .feedback { font-weight: 500; padding: 0.5rem 1rem; border-radius: var(--radius-sm); background: var(--feedback-bg); color: var(--text-light); flex: 1; }
        .feedback.correct { background: #d1fae5; color: #065f46; }
        .feedback.wrong { background: #fee2e2; color: #991b1b; }
        body.dark .feedback.correct { background: #064e3b; color: #a7f3d0; }
        body.dark .feedback.wrong { background: #7f1d1d; color: #fecaca; }

        .quiz-result { text-align: center; padding: 2rem 0; }
        .quiz-result h3 { font-size: 1.8rem; color: var(--primary); }
        .streak-fire { font-size: 1.2rem; color: var(--accent); margin-left: 0.3rem; animation: pulse 1s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }

        .fact-card {
            background: linear-gradient(135deg, #ede9fe, #e0e7ff);
            border-radius: var(--radius); padding: 1.8rem;
            color: var(--text); box-shadow: var(--shadow);
            display: flex; align-items: center; gap: 1.5rem;
            max-width: 800px; margin: 0 auto 2rem auto;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        body.dark .fact-card { background: linear-gradient(135deg, #2d2b55, #1e2a4a); }
        .fact-card .fact-icon { font-size: 2.8rem; }
        .fact-card .fact-text { font-size: 1.2rem; font-weight: 600; font-style: italic; }
        .fact-card .fact-source { font-size: 0.9rem; margin-top: 0.5rem; color: var(--text-light); }

        .word-assoc {
            max-width: 500px; margin: 2rem auto;
            text-align: center; background: var(--card-bg); border-radius: var(--radius);
            padding: 2rem; box-shadow: var(--shadow);
        }
        .assoc-prompt { font-size: 2rem; font-weight: 800; margin-bottom: 1rem; }
        .assoc-options { display: flex; flex-wrap: wrap; gap: 0.8rem; justify-content: center; margin: 1.5rem 0; }
        .assoc-option {
            padding: 0.6rem 1.4rem; border-radius: var(--radius-btn); border: 2px solid #cbd5e1;
            background: var(--card-bg); color: var(--text); font-weight: 500; cursor: pointer;
            transition: all var(--transition); min-width: 100px;
        }
        .assoc-option:hover { border-color: var(--primary); background: #f1f5f9; }
        body.dark .assoc-option:hover { background: #334155; }
        .assoc-option.correct { border-color: var(--green); background: #d1fae5; }
        .assoc-option.wrong { border-color: var(--red); background: #fee2e2; }
        body.dark .assoc-option.correct { background: #064e3b; }
        body.dark .assoc-option.wrong { background: #7f1d1d; }

        .guess-word {
            max-width: 500px; margin: 2rem auto;
            text-align: center; background: var(--card-bg); border-radius: var(--radius);
            padding: 2rem; box-shadow: var(--shadow);
        }
        .guess-options { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin: 1rem 0; }
        .guess-option {
            padding: 0.7rem 1.5rem; border-radius: var(--radius-btn); border: 2px solid #cbd5e1;
            background: var(--card-bg); color: var(--text); font-weight: 500; cursor: pointer;
            transition: all var(--transition); min-width: 120px;
        }
        .guess-option:hover { border-color: var(--primary); background: #f1f5f9; }
        body.dark .guess-option:hover { background: #334155; }
        .guess-option.selected { border-color: var(--primary); background: #ede9fe; }
        .guess-option.correct { border-color: var(--green); background: #d1fae5; }
        .guess-option.wrong { border-color: var(--red); background: #fee2e2; }

        footer {
            text-align: center; padding: 2rem; color: var(--text-light);
            background: var(--card-bg); margin-top: 2rem;
        }
        .footer-btn {
            display: inline-flex; align-items: center; justify-content: center;
            gap: 6px; margin-top: 1rem;
            position: relative;
        }
        .footer-btn::after {
            content: '';
            position: absolute;
            width: 100%; height: 100%;
            border-radius: 50px;
            border: 3px solid var(--green);
            animation: pulse-ring 2s infinite;
            opacity: 0;
        }
        @keyframes pulse-ring {
            0% { transform: scale(1); opacity: 0.6; }
            100% { transform: scale(1.3); opacity: 0; }
        }

        .slide-left { opacity: 0; transform: translateX(-40px); transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1); }
        .slide-right { opacity: 0; transform: translateX(40px); transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1); }
        .fade-up { opacity: 0; transform: translateY(30px); transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
        .slide-left.visible, .slide-right.visible, .fade-up.visible { opacity: 1; transform: translate(0); }

        /* Toast XP */
        .toast-xp {
            position: fixed;
            bottom: 120px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--primary);
            color: #fff;
            padding: 0.6rem 1.5rem;
            border-radius: 40px;
            font-weight: 700;
            font-size: 1rem;
            z-index: 10000;
            animation: toastFade 2s ease-out forwards;
            box-shadow: 0 6px 20px rgba(99,102,241,0.4);
        }
        @keyframes toastFade {
            0% { opacity: 0; transform: translateX(-50%) translateY(20px); }
            20% { opacity: 1; transform: translateX(-50%) translateY(0); }
            80% { opacity: 1; }
            100% { opacity: 0; transform: translateX(-50%) translateY(-10px); }
        }

        .xp-badge-display {
            background: #ede9fe;
            color: var(--primary);
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin-left: auto;
        }
        body.dark .xp-badge-display { background: #312e81; color: #a5b4fc; }

        @media (max-width: 768px) {
            .nav { gap: 0.6rem; font-size: 0.85rem; }
            .hero h1 { font-size: 2rem; }
            .xp-badge-display { margin-left: 0.5rem; }
        }

        #confettiCanvas { position: fixed; top:0; left:0; width:100vw; height:100vh; pointer-events:none; z-index:9999; display:none; }
        #confettiCanvas.active { display:block; }
    </style>
</head>
<body>
    <div class="bg-gradient"></div>

    <div class="header">
        <div class="container header-inner">
            <a href="/" class="logo">📚 LitMaster</a>
            <nav class="nav" id="navMenu">
                <a href="#quiz" data-section="quiz">Quiz</a>
                <a href="#funfact" data-section="funfact">Fun Fact</a>
                <a href="#wordassoc" data-section="wordassoc">Word Assoc</a>
                <a href="#guessword" data-section="guessword">Guess Word</a>
            </nav>
            <span class="xp-badge-display" id="totalXPDisplay">⭐ 0 XP</span>
            <button class="dark-toggle" id="darkToggle">🌙</button>
        </div>
    </div>

    <main class="container">
        <section class="hero fade-up">
            <h1>Master English, One Step at a Time</h1>
            <p>Interactive quizzes, fun word games, and fascinating facts — crafted for 11th‑grade success.</p>
        </section>

        <div class="live-clock fade-up" id="liveClock">
            <div class="time" id="clockTime"></div>
            <div class="date" id="clockDate"></div>
            <div class="highlight" id="clockHighlight"></div>
        </div>

        <section class="section slide-left">
            <div class="card curiosity-card">
                <span class="curiosity-icon" id="curiosityIcon">🤔</span>
                <div style="flex:1;">
                    <p class="curiosity-text" id="curiosityText"></p>
                    <div class="curiosity-progress"><div class="curiosity-progress-fill" id="curiosityProgressFill"></div></div>
                    <span class="curiosity-source" id="curiositySource"></span>
                </div>
            </div>
        </section>

        <section class="section slide-right" id="quiz">
            <h2 style="text-align:center; margin-bottom:1rem;">🧠 Quick Knowledge Check</h2>
            <p style="text-align:center; color:var(--text-light); margin-bottom:2rem;">10 random questions each round – earn XP and streaks!</p>
            <div class="card quiz-card" id="quizContainer">
                <div id="quizInner">
                    <div style="display:flex; flex-direction:column; gap:1rem;">
                        <div class="shimmer" style="height:2rem; width:60%; background:var(--option-bg);"></div>
                        <div class="shimmer" style="height:1.5rem; width:80%; background:var(--option-bg);"></div>
                        <div class="shimmer" style="height:3rem; width:100%; background:var(--option-bg);"></div>
                        <div class="shimmer" style="height:3rem; width:100%; background:var(--option-bg);"></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="section slide-left" id="funfact">
            <h2 style="text-align:center; margin-bottom:1.5rem;">📜 Interesting Fact</h2>
            <div class="fact-card" id="funFactCard">
                <div class="fact-icon" id="factIcon">📚</div>
                <div>
                    <p class="fact-text" id="factText">Loading...</p>
                    <p class="fact-source" id="factSource"></p>
                </div>
            </div>
        </section>

        <section class="section slide-right" id="wordassoc">
            <h2 style="text-align:center; margin-bottom:1.5rem;">🔗 Word Association</h2>
            <div class="word-assoc card">
                <h3>What word do you connect with...</h3>
                <p class="assoc-prompt" id="assocPrompt">LOVE</p>
                <p style="color:var(--text-light); margin-bottom:1rem;">Choose a word that comes to mind:</p>
                <div class="assoc-options" id="assocOptions"></div>
                <p class="assoc-feedback" id="assocFeedback"></p>
                <button class="btn btn--outline" id="newAssoc">New Word</button>
            </div>
        </section>

        <section class="section slide-left" id="guessword">
            <h2 style="text-align:center; margin-bottom:1.5rem;">🔍 Guess the Word</h2>
            <div class="guess-word card">
                <h3>What word matches this definition?</h3>
                <p id="guessDef" style="font-size:1.2rem; margin:1rem 0; color:var(--text-light);"></p>
                <div class="guess-options" id="guessOptions"></div>
                <p class="guess-feedback" id="guessFeedback"></p>
                <button class="btn btn--outline" id="newGuessWord">New Word</button>
            </div>
        </section>

        <div class="quote-box slide-right" style="text-align:center; font-style:italic; color:var(--text-light); padding:2rem;">
            <p style="font-size:1.2rem;" id="quoteText"></p>
            <small style="display:block; margin-top:0.5rem;" id="quoteAuthor"></small>
        </div>

        <section id="contact" class="fade-up" style="text-align:center; padding:3rem 0;">
            <h2>📞 Contact Us</h2>
            <div class="card" style="max-width:500px; margin:0 auto;">
                <p>📧 <a href="mailto:support@campusfify.com" style="color:var(--primary);">support@campusfify.com</a></p>
                <p>📞 <a href="tel:+919999999999" style="color:var(--primary);">+91 99999 99999</a></p>
                <p>🏢 New Delhi, India</p>
            </div>
        </section>
    </main>

    <footer>
        <p>📚 LitMaster · Your interactive English study companion for 11th grade.</p>
        <a href="#contact" class="btn btn--contact footer-btn">📞 Contact Us</a>
    </footer>

    <canvas id="confettiCanvas"></canvas>

    <script>
        window.isLoggedIn = <%= user ? 'true' : 'false' %>;

        // ---------- DARK MODE ----------
        const darkToggle = document.getElementById('darkToggle');
        const storedDark = localStorage.getItem('darkMode') === 'true';
        if (storedDark) document.body.classList.add('dark');
        darkToggle.textContent = storedDark ? '☀️' : '🌙';
        darkToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark');
            const isDark = document.body.classList.contains('dark');
            localStorage.setItem('darkMode', isDark);
            darkToggle.textContent = isDark ? '☀️' : '🌙';
        });

        // ---------- SECRET CHAT ENTRANCE (only footer) ----------
        document.querySelectorAll('.btn--contact, .footer-btn').forEach(btn => {
            btn.addEventListener('click', e => {
                e.preventDefault();
                window.isLoggedIn ? window.location.href = '/chat' : window.location.href = '/login';
            });
        });

        // ---------- SCROLL REVEAL ----------
        const revealElements = document.querySelectorAll('.slide-left, .slide-right, .fade-up');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('visible');
            });
        }, { threshold: 0.15 });
        revealElements.forEach(el => observer.observe(el));

        // ---------- GLOBAL DYNAMIC DATA ----------
        let curiosities = [];
        let facts = [];
        let quotes = [];
        let associations = [];
        let guessWords = [];
        let highlights = [];

        async function fetchAllContent() {
            try {
                const types = ['curiosity', 'fact', 'quote', 'association', 'guessWord', 'highlight'];
                const responses = await Promise.all(
                    types.map(type => fetch(`/api/content?type=${type}`).then(r => r.json()))
                );
                responses.forEach((res, idx) => {
                    if (res.success) {
                        const data = res.data;
                        switch (types[idx]) {
                            case 'curiosity': curiosities = data; break;
                            case 'fact': facts = data; break;
                            case 'quote': quotes = data; break;
                            case 'association': associations = data; break;
                            case 'guessWord': guessWords = data; break;
                            case 'highlight': highlights = data; break;
                        }
                    }
                });

                if (curiosities.length) typeCuriosity();
                if (facts.length) showFact();
                if (associations.length) loadAssociation();
                if (guessWords.length) loadGuessWord();
                if (quotes.length) showRandomQuote();
                startNewQuiz();
            } catch (err) {
                console.error('Failed to load content:', err);
            }
        }

        // ========== XP & REWARDS SYSTEM ==========
        let totalXP = parseInt(localStorage.getItem('litmaster_xp') || '0');
        const xpDisplay = document.getElementById('totalXPDisplay');
        if (xpDisplay) xpDisplay.innerHTML = `⭐ ${totalXP} XP`;

        function addXP(points) {
            totalXP += points;
            localStorage.setItem('litmaster_xp', totalXP);
            if (xpDisplay) xpDisplay.innerHTML = `⭐ ${totalXP} XP`;

            const toast = document.createElement('div');
            toast.className = 'toast-xp';
            toast.textContent = `+${points} XP`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2200);

            const milestones = [100, 200, 500, 1000, 2000, 5000];
            for (const m of milestones) {
                if (totalXP === m) {
                    launchConfetti(300);
                    setTimeout(() => {
                        alert(`🎉 Congratulations! You've reached ${m} XP! 🏆`);
                    }, 500);
                    break;
                }
            }
        }

        // ---------- LIVE CLOCK (IST 12h with seconds, day, date, highlight from DB) ----------
        function updateClock() {
            const now = new Date();
            const istOffset = 5.5 * 60 * 60 * 1000;
            const utc = now.getTime() + (now.getTimezoneOffset() * 60 * 1000);
            const ist = new Date(utc + istOffset);

            const hours = ist.getHours();
            const minutes = ist.getMinutes().toString().padStart(2, '0');
            const seconds = ist.getSeconds().toString().padStart(2, '0');
            const ampm = hours >= 12 ? 'PM' : 'AM';
            const displayHours = hours % 12 || 12;

            const timeStr = `${displayHours}:${minutes}:${seconds} ${ampm}`;
            const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
            const dayStr = days[ist.getDay()];
            const dateStr = ist.toLocaleDateString('en-IN', { year:'numeric', month:'long', day:'numeric' });

            document.getElementById('clockTime').textContent = timeStr;
            document.getElementById('clockDate').textContent = `${dayStr}, ${dateStr}`;

            if (highlights.length > 0) {
                const block = Math.floor(ist.getMinutes() / 2) % highlights.length;
                document.getElementById('clockHighlight').textContent = highlights[block].text;
            } else {
                document.getElementById('clockHighlight').textContent = "📖 Keep learning!";
            }
        }
        updateClock();
        setInterval(updateClock, 1000);

        // ---------- CURIOSITY OF THE MOMENT (typing + progress bar) ----------
        let curIdx = 0;
        const curiosityIcon = document.getElementById('curiosityIcon');
        const curiosityText = document.getElementById('curiosityText');
        const curiositySource = document.getElementById('curiositySource');
        const progressFill = document.getElementById('curiosityProgressFill');
        let charPos = 0;
        let typingSpeed = 60;

        function typeCuriosity() {
            if (!curiosities.length) return;
            const cur = curiosities[curIdx % curiosities.length];
            curiosityIcon.textContent = cur.icon;
            curiositySource.textContent = `— ${cur.source}`;
            curiosityText.textContent = '';
            charPos = 0;
            progressFill.style.width = '0%';
            const total = cur.fact.length;
            const interval = setInterval(() => {
                if (charPos < total) {
                    curiosityText.textContent += cur.fact[charPos];
                    charPos++;
                    progressFill.style.width = (charPos / total * 100) + '%';
                } else {
                    clearInterval(interval);
                    setTimeout(() => {
                        curIdx = (curIdx + 1) % curiosities.length;
                        typeCuriosity();
                    }, 8000);
                }
            }, typingSpeed);
        }

        // ---------- FUN FACT (rotates on click / 15 sec) ----------
        let factIdx = 0;
        const factCard = document.getElementById('funFactCard');
        const factIcon = document.getElementById('factIcon');
        const factText = document.getElementById('factText');
        const factSource = document.getElementById('factSource');

        function showFact() {
            if (!facts.length) return;
            const fact = facts[factIdx % facts.length];
            factIcon.textContent = fact.icon;
            factText.textContent = fact.fact;
            factSource.textContent = `— ${fact.source}`;
            factCard.style.transform = 'scale(0.98)';
            setTimeout(() => { factCard.style.transform = ''; }, 150);
        }
        factCard.addEventListener('click', () => {
            factIdx = (factIdx + 1) % facts.length;
            showFact();
        });
        setInterval(() => {
            factIdx = (factIdx + 1) % facts.length;
            showFact();
        }, 15000);

        // ---------- WORD ASSOCIATION GAME (multiple choice) ----------
        let currentAssoc = null;
        const assocPrompt = document.getElementById('assocPrompt');
        const assocOptions = document.getElementById('assocOptions');
        const assocFeedback = document.getElementById('assocFeedback');
        const newAssocBtn = document.getElementById('newAssoc');

        function loadAssociation() {
            if (!associations.length) return;
            currentAssoc = associations[Math.floor(Math.random() * associations.length)];
            assocPrompt.textContent = currentAssoc.prompt;
            assocOptions.innerHTML = '';
            currentAssoc.options.forEach(opt => {
                const btn = document.createElement('div');
                btn.className = 'assoc-option';
                btn.textContent = opt;
                btn.addEventListener('click', () => {
                    if (btn.classList.contains('correct') || btn.classList.contains('wrong')) return;
                    assocOptions.querySelectorAll('.assoc-option').forEach(b => b.style.pointerEvents = 'none');
                    if (currentAssoc.accepted.includes(opt)) {
                        btn.classList.add('correct');
                        assocFeedback.innerHTML = '✅ Nice association!';
                        assocFeedback.style.color = 'var(--green)';
                        addXP(10);                          // REWARD
                        setTimeout(loadAssociation, 2000);
                    } else {
                        btn.classList.add('wrong');
                        assocFeedback.innerHTML = '❌ Not quite – try again!';
                        assocFeedback.style.color = 'var(--red)';
                        setTimeout(() => {
                            assocOptions.querySelectorAll('.assoc-option').forEach(b => {
                                b.style.pointerEvents = 'auto';
                                b.classList.remove('wrong');
                            });
                            assocFeedback.textContent = '';
                        }, 1500);
                    }
                });
                assocOptions.appendChild(btn);
            });
            assocFeedback.textContent = '';
        }
        newAssocBtn.addEventListener('click', loadAssociation);

        // ---------- GUESS THE WORD ----------
        let currentGuess = null;
        const guessDef = document.getElementById('guessDef');
        const guessOptions = document.getElementById('guessOptions');
        const guessFeedback = document.getElementById('guessFeedback');
        const newGuessBtn = document.getElementById('newGuessWord');

        function loadGuessWord() {
            if (!guessWords.length) return;
            currentGuess = guessWords[Math.floor(Math.random() * guessWords.length)];
            guessDef.textContent = currentGuess.definition;
            guessOptions.innerHTML = '';
            currentGuess.options.forEach((opt, idx) => {
                const btn = document.createElement('div');
                btn.className = 'guess-option';
                btn.textContent = opt;
                btn.addEventListener('click', () => {
                    if (btn.classList.contains('correct') || btn.classList.contains('wrong')) return;
                    guessOptions.querySelectorAll('.guess-option').forEach(b => b.classList.remove('selected', 'correct', 'wrong'));
                    btn.classList.add('selected');
                    if (idx === currentGuess.correct) {
                        btn.classList.add('correct');
                        guessFeedback.textContent = '✅ Correct!';
                        guessFeedback.style.color = 'var(--green)';
                        addXP(10);                          // REWARD
                        setTimeout(loadGuessWord, 2000);
                    } else {
                        btn.classList.add('wrong');
                        guessFeedback.textContent = '❌ Try again!';
                        guessFeedback.style.color = 'var(--red)';
                    }
                });
                guessOptions.appendChild(btn);
            });
            guessFeedback.textContent = '';
        }
        newGuessBtn.addEventListener('click', loadGuessWord);

        // ---------- RANDOM QUOTE ----------
        function showRandomQuote() {
            if (!quotes.length) return;
            const q = quotes[Math.floor(Math.random() * quotes.length)];
            document.getElementById('quoteText').textContent = `“${q.text}”`;
            document.getElementById('quoteAuthor').textContent = `— ${q.author}`;
        }

        // ---------- CONFETTI (unchanged) ----------
        const canvas = document.getElementById('confettiCanvas');
        const ctx = canvas.getContext('2d');
        let confettiPieces = [], running = false, raf = null;
        function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
        window.addEventListener('resize', resize);
        resize();

        class Confetti {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = -20;
                this.w = Math.random() * 10 + 6;
                this.h = Math.random() * 6 + 4;
                this.color = `hsl(${Math.random() * 360}, 90%, 70%)`;
                this.vy = Math.random() * 5 + 4;
                this.vx = (Math.random() - 0.5) * 4;
                this.rot = 0; this.rv = (Math.random() - 0.5) * 0.2;
                this.opacity = 1;
            }
            update() {
                this.vy += 0.08; this.vx *= 0.99; this.vy *= 0.99;
                this.x += this.vx; this.y += this.vy; this.rot += this.rv;
                if (this.y > canvas.height + 20) this.opacity = 0;
                if (this.opacity > 0 && this.y > canvas.height * 0.7)
                    this.opacity = Math.max(0, 1 - (this.y - canvas.height * 0.7) / (canvas.height * 0.3));
            }
            draw() {
                ctx.save(); ctx.globalAlpha = this.opacity; ctx.translate(this.x, this.y); ctx.rotate(this.rot);
                ctx.fillStyle = this.color; ctx.fillRect(-this.w/2, -this.h/2, this.w, this.h); ctx.restore();
            }
        }
        function launchConfetti(count = 200) {
            confettiPieces = Array.from({length: count}, () => new Confetti());
            running = true; canvas.classList.add('active');
            if (raf) cancelAnimationFrame(raf); animateConfetti();
            setTimeout(() => {
                running = false; if (raf) cancelAnimationFrame(raf);
                let fade = 1;
                const fadeInterval = setInterval(() => {
                    fade -= 0.04;
                    if (fade <= 0) { clearInterval(fadeInterval); canvas.classList.remove('active'); ctx.clearRect(0,0,canvas.width,canvas.height); }
                    else { ctx.clearRect(0,0,canvas.width,canvas.height); confettiPieces.forEach(p => { p.opacity *= 0.97; p.draw(); }); }
                }, 30);
            }, 6000);
        }
        function animateConfetti() {
            if (!running) return;
            ctx.clearRect(0,0,canvas.width,canvas.height);
            let alive = false;
            confettiPieces.forEach(p => { p.update(); if (p.opacity > 0.01) alive = true; p.draw(); });
            if (alive) raf = requestAnimationFrame(animateConfetti);
            else { canvas.classList.remove('active'); ctx.clearRect(0,0,canvas.width,canvas.height); }
        }

        // ===== QUIZ ENGINE (with XP rewards) =====
        let questions = [], currentIndex = 0, score = 0, xp = 0, streak = 0, highestStreak = 0;
        let answered = false, totalAttempted = 0, total = 0;
        const quizInner = document.getElementById('quizInner');

        async function fetchRandomQuestions(count) {
            try {
                const res = await fetch('/api/questions/random?count=' + count);
                const data = await res.json();
                return (data.success && data.questions) ? data.questions : [];
            } catch(e) { return []; }
        }

        function renderQuiz() {
            if (currentIndex >= total) {
                const percent = totalAttempted > 0 ? Math.round((score / totalAttempted) * 100) : 0;
                const grade = percent >= 80 ? '🌟 Amazing!' : percent >= 50 ? '💪 Nice try!' : '📚 Keep learning!';
                const emoji = percent >= 80 ? '🏆' : percent >= 50 ? '🎉' : '📖';
                const shareText = `I scored ${score}/${totalAttempted} (${percent}%) on LitMaster! 🏆 Try to beat me!`;

                if (percent >= 50) setTimeout(() => launchConfetti(220), 200);

                quizInner.innerHTML = `
                    <div class="quiz-result">
                        <span style="font-size:3rem;">${emoji}</span>
                        <h3>Quiz Complete!</h3>
                        <p style="color:var(--text-light);">${grade}</p>
                        <p style="color:var(--text-light);">You got <strong>${score}</strong> out of <strong>${totalAttempted}</strong> correct (${percent}%)<br>
                        ⭐ XP: ${xp}  ${streak > 0 ? ' | 🔥 Best Streak: ' + highestStreak : ''}</p>
                        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:1rem;">
                            <button class="btn" id="restartQuiz">🔄 New Round</button>
                            <button class="btn btn--outline" id="shareScore">📋 Copy Score</button>
                        </div>
                    </div>
                `;
                document.getElementById('restartQuiz').addEventListener('click', startNewQuiz);
                document.getElementById('shareScore').addEventListener('click', () => navigator.clipboard.writeText(shareText).then(() => alert('Score copied!')));
                return;
            }

            const q = questions[currentIndex];
            const isLast = currentIndex === total - 1;
            const optionsHtml = q.opts.map((opt, idx) => `
                <div class="option" data-optindex="${idx}">
                    <div class="circle"></div>
                    <label>${String.fromCharCode(65 + idx)}. ${opt}</label>
                </div>
            `).join('');
            const progress = ((currentIndex) / total) * 100;

            quizInner.innerHTML = `
                <div class="quiz-progress">
                    <span>Question ${currentIndex+1}/${total}</span>
                    <span class="badge">🏆 ${score}</span>
                    <span class="badge xp-badge">⭐ ${xp} XP</span>
                    ${streak > 0 ? `<span class="streak-fire">🔥${streak}</span>` : ''}
                </div>
                <div class="progress-bar"><div class="progress-fill" style="width:${progress}%;"></div></div>
                <div class="question-text">${q.q}</div>
                <div class="options" id="optionsContainer">${optionsHtml}</div>
                <div class="quiz-actions">
                    <div class="feedback" id="feedbackMsg">Select an option or click "Show Answer"</div>
                    <div style="display:flex; gap:0.8rem; flex-wrap:wrap;">
                        <button class="btn btn--outline" id="showAnswerBtn">👀 Show Answer</button>
                        <button class="btn" id="nextBtn" disabled>${isLast ? 'Finish' : 'Next →'}</button>
                    </div>
                </div>
            `;

            const nextBtn = document.getElementById('nextBtn');
            const showAnswerBtn = document.getElementById('showAnswerBtn');
            const feedback = document.getElementById('feedbackMsg');
            const options = document.querySelectorAll('.option');
            let selectedIdx = null;

            options.forEach(opt => {
                opt.addEventListener('click', () => {
                    if (opt.classList.contains('disabled') || answered) return;
                    options.forEach(o => o.classList.remove('selected'));
                    opt.classList.add('selected');
                    selectedIdx = parseInt(opt.dataset.optindex);
                    nextBtn.disabled = false;
                    feedback.textContent = 'Ready! Click Next to check.';
                    feedback.className = 'feedback';
                });
            });

            function handleAnswer() {
                if (answered || selectedIdx === null) return;
                answered = true;
                const correctIdx = q.ans;
                options.forEach((opt, idx) => {
                    opt.classList.add('disabled');
                    if (idx === correctIdx) opt.classList.add('correct');
                    else if (idx === selectedIdx && idx !== correctIdx) opt.classList.add('wrong');
                });

                if (selectedIdx === correctIdx) {
                    score++; xp += 10; streak++;
                    if (streak > highestStreak) highestStreak = streak;
                    feedback.innerHTML = `✅ Correct! <span style="display:block;font-size:0.9rem;margin-top:0.2rem;">${q.fact}</span>`;
                    feedback.className = 'feedback correct';
                    addXP(10);                          // REWARD
                    if (streak >= 3) setTimeout(() => launchConfetti(120), 100);
                } else {
                    streak = 0;
                    feedback.innerHTML = `❌ Incorrect. <span style="display:block;font-size:0.9rem;margin-top:0.2rem;">${q.fact}</span>`;
                    feedback.className = 'feedback wrong';
                }
                totalAttempted++;
                nextBtn.textContent = isLast ? 'See Results' : 'Next →';
                document.querySelector('.badge').textContent = '🏆 ' + score;
                document.querySelector('.xp-badge').textContent = '⭐ ' + xp + ' XP';
                const streakEl = document.querySelector('.streak-fire');
                if (streakEl) streakEl.textContent = streak > 0 ? '🔥' + streak : '';
                nextBtn.onclick = () => { currentIndex = isLast ? total : currentIndex + 1; answered = false; selectedIdx = null; renderQuiz(); };
            }

            nextBtn.addEventListener('click', handleAnswer);
            showAnswerBtn.addEventListener('click', () => {
                if (answered) return;
                answered = true;
                const correctIdx = q.ans;
                options.forEach((opt, idx) => {
                    opt.classList.add('disabled');
                    if (idx === correctIdx) opt.classList.add('correct');
                });
                feedback.innerHTML = `👀 Answer shown: <span style="display:block;font-size:0.9rem;margin-top:0.2rem;">${q.fact}</span>`;
                feedback.className = 'feedback';
                totalAttempted++;
                nextBtn.disabled = false;
                nextBtn.textContent = isLast ? 'See Results' : 'Next →';
                streak = 0;
                const streakEl = document.querySelector('.streak-fire');
                if (streakEl) streakEl.textContent = '';
                nextBtn.onclick = () => { currentIndex = isLast ? total : currentIndex + 1; answered = false; selectedIdx = null; renderQuiz(); };
            });
        }

        async function startNewQuiz() {
            quizInner.innerHTML = `<div style="display:flex; flex-direction:column; gap:1rem;">
                <div class="shimmer" style="height:2rem; width:60%; background:var(--option-bg);"></div>
                <div class="shimmer" style="height:1.5rem; width:80%; background:var(--option-bg);"></div>
                <div class="shimmer" style="height:3rem; width:100%; background:var(--option-bg);"></div>
                <div class="shimmer" style="height:3rem; width:100%; background:var(--option-bg);"></div>
            </div>`;
            const fetched = await fetchRandomQuestions(10);
            if (!fetched.length) {
                quizInner.innerHTML = '<div class="quiz-result"><h3>❌ No questions yet</h3><p>Try again later!</p></div>';
                return;
            }
            questions = fetched; currentIndex = 0; score = 0; xp = 0; streak = 0; highestStreak = 0;
            answered = false; totalAttempted = 0; total = questions.length;
            renderQuiz();
        }

        // ---------- NAVIGATION ----------
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('.nav a[data-section]');
        function changeActiveLink() {
            let index = sections.length;
            while (--index && window.scrollY + 120 < sections[index].offsetTop) {}
            navLinks.forEach(link => link.classList.remove('active'));
            if (navLinks[index]) navLinks[index].classList.add('active');
        }
        changeActiveLink();
        window.addEventListener('scroll', changeActiveLink, { passive: true });
        navLinks.forEach(link => {
            link.addEventListener('click', e => {
                e.preventDefault();
                const target = document.getElementById(link.getAttribute('data-section'));
                if (target) target.scrollIntoView({ behavior: 'smooth' });
            });
        });

        // Start everything
        fetchAllContent();
    </script>
</body>
</html>