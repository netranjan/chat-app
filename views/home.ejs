<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>LitMaster · English Study Hub</title>
    
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg: #fafbff;
            --card-bg: #ffffff;
            --text: #1e293b;
            --text-light: #475569;
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --accent: #f59e0b;
            --green: #10b981;
            --red: #ef4444;
            --shadow: 0 4px 20px rgba(0,0,0,0.05);
            --shadow-lg: 0 8px 32px rgba(0,0,0,0.08);
            --radius: 16px;
            --radius-sm: 12px;
            --radius-btn: 12px;
            --transition: 0.2s ease-in-out;
            --font: 'Inter', system-ui, -apple-system, sans-serif;
            --option-bg: #f1f5f9;
            --feedback-bg: #f1f5f9;
        }

        body.dark {
            --bg: #0f172a;
            --card-bg: #1e293b;
            --text: #f1f5f9;
            --text-light: #94a3b8;
            --primary: #818cf8;
            --primary-hover: #6366f1;
            --accent: #fbbf24;
            --green: #34d399;
            --red: #f87171;
            --shadow: 0 4px 20px rgba(0,0,0,0.3);
            --shadow-lg: 0 8px 32px rgba(0,0,0,0.5);
            --option-bg: #334155;
            --feedback-bg: #334155;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            transition: background 0.3s, color 0.3s;
            overflow-x: hidden;
        }

        /* Live background animation */
        .live-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; overflow: hidden; pointer-events: none;
        }
        .live-bg span {
            position: absolute; display: block; border-radius: 50%;
            opacity: 0.12; animation: float 30s infinite ease-in-out;
        }
        .live-bg span:nth-child(1) { left: 15%; top: 25%; width: 120px; height: 120px; background: var(--primary); animation-delay: 0s; }
        .live-bg span:nth-child(2) { left: 70%; top: 60%; width: 150px; height: 150px; background: var(--accent); animation-delay: -8s; }
        .live-bg span:nth-child(3) { left: 40%; top: 80%; width: 90px; height: 90px; background: var(--green); animation-delay: -16s; }
        .live-bg span:nth-child(4) { left: 80%; top: 15%; width: 100px; height: 100px; background: var(--primary); animation-delay: -24s; }
        @keyframes float {
            0% { transform: translateY(0) rotate(0deg) scale(1); }
            50% { transform: translateY(-50px) rotate(180deg) scale(1.1); }
            100% { transform: translateY(0) rotate(360deg) scale(1); }
        }

        .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

        /* Buttons */
        .btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            background: var(--primary); color: #fff;
            font-weight: 600; font-size: 0.95rem; padding: 0.75rem 1.8rem;
            border: none; border-radius: var(--radius-btn); cursor: pointer;
            text-decoration: none; transition: all var(--transition);
            white-space: nowrap; box-shadow: 0 4px 12px rgba(99,102,241,0.3);
        }
        .btn:hover { background: var(--primary-hover); transform: translateY(-2px); box-shadow: 0 8px 20px rgba(99,102,241,0.4); }
        .btn:active { transform: scale(0.97); }
        .btn--outline { background: transparent; color: var(--primary); box-shadow: 0 0 0 2px var(--primary); }
        .btn--outline:hover { background: rgba(99,102,241,0.08); }
        .btn--sm { padding: 0.5rem 1.2rem; font-size: 0.85rem; }
        .btn--contact {
            background: var(--green); color: #fff;
            box-shadow: 0 4px 12px rgba(16,185,129,0.3);
        }
        .btn--contact:hover { background: #059669; }

        /* Header */
        .header {
            position: sticky; top: 0; z-index: 100;
            background: rgba(255,255,255,0.8); backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0,0,0,0.04);
            padding: 0.8rem 0;
            transition: background 0.3s;
        }
        body.dark .header { background: rgba(15,23,42,0.85); border-color: rgba(255,255,255,0.05); }
        .header-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
        .logo {
            font-weight: 800; font-size: 1.6rem; color: var(--primary);
            text-decoration: none; letter-spacing: -0.5px;
        }
        .nav { display: flex; align-items: center; gap: 1.5rem; font-weight: 500; flex-wrap: wrap; }
        .nav a {
            color: var(--text-light); text-decoration: none; padding: 0.3rem 0;
            border-bottom: 2px solid transparent; transition: all var(--transition);
            white-space: nowrap;
        }
        .nav a:hover, .nav a.active { color: var(--primary); border-bottom-color: var(--primary); }
        .nav .contact-link {
            background: var(--green); color: #fff !important;
            padding: 0.5rem 1.5rem; border-radius: 40px; border-bottom: none;
        }
        .nav .contact-link:hover { background: #059669; }
        .dark-toggle { background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--text); margin-left: auto; }

        /* Hero */
        .hero { padding: 4rem 0 3rem; text-align: center; }
        .hero h1 {
            font-size: clamp(2.4rem, 8vw, 4rem); font-weight: 800;
            background: linear-gradient(135deg, #6366f1, #a78bfa);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }
        .hero p { font-size: 1.15rem; color: var(--text-light); max-width: 550px; margin: 0 auto; }

        /* Cards */
        .section { padding: 2rem 0; }
        .card {
            background: var(--card-bg); border-radius: var(--radius);
            padding: 2rem; box-shadow: var(--shadow);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
        .card h3 { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.8rem; }

        /* Tip card */
        .tip-card {
            border-left: 6px solid var(--primary);
            display: flex; align-items: center; gap: 1.2rem;
        }
        .tip-icon { font-size: 2.2rem; }
        .tip-text { font-weight: 600; color: var(--text); min-height: 3rem; }
        .tip-category {
            font-size: 0.75rem; background: #ede9fe; color: var(--primary);
            padding: 0.2rem 1rem; border-radius: 20px; display: inline-block;
            text-transform: uppercase; font-weight: 600; margin-top: 0.4rem;
        }
        body.dark .tip-category { background: #312e81; color: #a5b4fc; }

        /* Quiz */
        .quiz-card { max-width: 800px; margin: 0 auto; }
        .quiz-progress { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; font-weight: 600; color: var(--text-light); flex-wrap: wrap; gap: 0.5rem; }
        .badge {
            background: #ede9fe; color: var(--primary); padding: 0.25rem 0.8rem; border-radius: 20px;
            font-size: 0.8rem; font-weight: 700;
        }
        .xp-badge { background: #dbeafe; color: #2563eb; }
        body.dark .badge { background: #312e81; color: #a5b4fc; }
        body.dark .xp-badge { background: #1e3a5f; color: #93c5fd; }
        .progress-bar { width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; margin: 0.8rem 0 1.2rem; overflow: hidden; }
        body.dark .progress-bar { background: #334155; }
        .progress-fill { height: 100%; background: var(--primary); border-radius: 10px; transition: width 0.3s; }
        .question-text { font-size: 1.3rem; font-weight: 700; margin-bottom: 1.2rem; }
        .options { display: flex; flex-direction: column; gap: 0.7rem; margin-bottom: 1rem; }
        .option {
            display: flex; align-items: center; gap: 0.8rem; padding: 1rem 1.2rem;
            background: var(--option-bg); border-radius: var(--radius-sm);
            border: 2px solid transparent;
            cursor: pointer; transition: all var(--transition); font-size: 1rem; user-select: none;
        }
        .option:hover:not(.disabled) { border-color: var(--primary); background: var(--card-bg); }
        .option input[type="radio"] { display: none; }
        .option .circle {
            width: 20px; height: 20px; border-radius: 50%; border: 2px solid #cbd5e1;
            display: flex; align-items: center; justify-content: center; transition: 0.2s;
        }
        body.dark .option .circle { border-color: #64748b; }
        .option.selected .circle { border-color: var(--primary); background: var(--primary); }
        .option.selected .circle::after { content: ''; width: 8px; height: 8px; background: #fff; border-radius: 50%; }
        .option label { flex: 1; font-weight: 500; cursor: pointer; color: var(--text); }
        .option.correct { background: #d1fae5; border-color: var(--green); }
        .option.wrong { background: #fee2e2; border-color: var(--red); }
        body.dark .option.correct { background: #064e3b; }
        body.dark .option.wrong { background: #7f1d1d; }
        .option.disabled { pointer-events: none; opacity: 0.7; }
        .quiz-actions { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.8rem; margin-top: 0.8rem; }
        .feedback { font-weight: 500; padding: 0.5rem 1rem; border-radius: var(--radius-sm); background: var(--feedback-bg); color: var(--text-light); flex: 1; }
        .feedback.correct { background: #d1fae5; color: #065f46; }
        .feedback.wrong { background: #fee2e2; color: #991b1b; }
        body.dark .feedback.correct { background: #064e3b; color: #a7f3d0; }
        body.dark .feedback.wrong { background: #7f1d1d; color: #fecaca; }

        .quiz-result { text-align: center; padding: 2rem 0; }
        .quiz-result h3 { font-size: 1.8rem; color: var(--primary); }
        .streak-fire { font-size: 1.2rem; color: var(--accent); margin-left: 0.3rem; animation: pulse 1s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }

        /* New engaging sections */
        .fact-card {
            background: linear-gradient(135deg, #ede9fe, #e0e7ff);
            border-radius: var(--radius); padding: 1.8rem;
            color: var(--text); box-shadow: var(--shadow);
            display: flex; align-items: center; gap: 1.5rem;
            max-width: 800px; margin: 0 auto 2rem auto;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        body.dark .fact-card { background: linear-gradient(135deg, #2d2b55, #1e2a4a); }
        .fact-card .fact-icon { font-size: 2.8rem; }
        .fact-card .fact-text { font-size: 1.2rem; font-weight: 600; font-style: italic; }
        .fact-card .fact-source { font-size: 0.9rem; margin-top: 0.5rem; color: var(--text-light); }

        .word-jumble {
            max-width: 500px; margin: 2rem auto;
            text-align: center; background: var(--card-bg); border-radius: var(--radius);
            padding: 2rem; box-shadow: var(--shadow);
        }
        .word-jumble h3 { margin-bottom: 1rem; }
        .scrambled-word { font-size: 2.5rem; letter-spacing: 0.3rem; font-weight: 700; margin-bottom: 1rem; }
        .jumble-input {
            padding: 0.75rem 1.2rem; border-radius: var(--radius-btn); border: 2px solid #cbd5e1;
            font-size: 1rem; font-family: var(--font); width: 100%; margin-bottom: 1rem;
            background: var(--card-bg); color: var(--text);
            transition: border-color var(--transition);
        }
        .jumble-input:focus { outline: none; border-color: var(--primary); }
        .jumble-feedback { font-weight: 600; margin-top: 0.5rem; }

        /* Shimmer loading */
        .shimmer {
            background: linear-gradient(90deg, var(--card-bg) 25%, rgba(255,255,255,0.1) 50%, var(--card-bg) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
            border-radius: var(--radius-sm);
        }
        @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

        /* Footer */
        footer {
            text-align: center; padding: 2rem; color: var(--text-light);
            background: var(--card-bg); margin-top: 2rem;
            position: relative;
        }
        .footer-btn {
            display: inline-flex; align-items: center; justify-content: center;
            gap: 6px; margin-top: 1rem;
            position: relative;
        }
        /* Circular animation to attract click */
        .footer-btn::after {
            content: '';
            position: absolute;
            width: 100%; height: 100%;
            border-radius: 50px;
            border: 3px solid var(--green);
            animation: pulse-ring 2s infinite;
            opacity: 0;
        }
        @keyframes pulse-ring {
            0% { transform: scale(1); opacity: 0.6; }
            100% { transform: scale(1.3); opacity: 0; }
        }

        /* Scroll animations */
        .fade-up { opacity: 0; transform: translateY(30px); transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
        .fade-up.visible { opacity: 1; transform: translateY(0); }

        @media (max-width: 768px) {
            .nav { gap: 0.8rem; font-size: 0.9rem; }
            .hero h1 { font-size: 2rem; }
        }

        #confettiCanvas { position: fixed; top:0; left:0; width:100vw; height:100vh; pointer-events:none; z-index:9999; display:none; }
        #confettiCanvas.active { display:block; }
    </style>
</head>
<body>
    <!-- Live background animation -->
    <div class="live-bg">
        <span></span><span></span><span></span><span></span>
    </div>

    <div class="header">
        <div class="container header-inner">
            <a href="/" class="logo">📚 LitMaster</a>
            <nav class="nav" id="navMenu">
                <a href="#quiz" data-section="quiz">Quiz</a>
                <a href="#funfact" data-section="funfact">Fun Fact</a>
                <a href="#wordjumble" data-section="wordjumble">Word Jumble</a>
                <a href="#contact" class="contact-link">📞 Contact Us</a>
            </nav>
            <button class="dark-toggle" id="darkToggle">🌙</button>
        </div>
    </div>

    <main class="container">
        <!-- Hero -->
        <section class="hero">
            <h1>Master English, One Step at a Time</h1>
            <p>Interactive quizzes, engaging word games, and fascinating facts — crafted for 11th‑grade success.</p>
        </section>

        <!-- Typing Tip -->
        <section class="section fade-up">
            <div class="card tip-card">
                <span class="tip-icon">💡</span>
                <div>
                    <p class="tip-text" id="typingTip"></p>
                    <span class="tip-category" id="tipCategory"></span>
                </div>
            </div>
        </section>

        <!-- Quiz -->
        <section class="section fade-up" id="quiz">
            <h2 style="text-align:center; margin-bottom:1rem;">🧠 Quick Knowledge Check</h2>
            <p style="text-align:center; color:var(--text-light); margin-bottom:2rem;">10 random questions each round – earn XP and streaks!</p>
            <div class="card quiz-card" id="quizContainer">
                <div id="quizInner">
                    <!-- Shimmer loading placeholder -->
                    <div style="display:flex; flex-direction:column; gap:1rem;">
                        <div class="shimmer" style="height:2rem; width:60%;"></div>
                        <div class="shimmer" style="height:1.5rem; width:80%;"></div>
                        <div class="shimmer" style="height:3rem; width:100%;"></div>
                        <div class="shimmer" style="height:3rem; width:100%;"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Fun Fact Section -->
        <section class="section fade-up" id="funfact">
            <h2 style="text-align:center; margin-bottom:1.5rem;">📜 Literary Fun Fact</h2>
            <div class="fact-card" id="funFactCard">
                <div class="fact-icon" id="factIcon">📚</div>
                <div>
                    <p class="fact-text" id="factText">Loading...</p>
                    <p class="fact-source" id="factSource"></p>
                </div>
            </div>
        </section>

        <!-- Word Jumble Section -->
        <section class="section fade-up" id="wordjumble">
            <h2 style="text-align:center; margin-bottom:1.5rem;">🎲 Word Jumble</h2>
            <div class="word-jumble card">
                <h3>Unscramble the word</h3>
                <div class="scrambled-word" id="scrambledWord">-----</div>
                <p style="color:var(--text-light); margin-bottom:1rem;">Type the correct word:</p>
                <input type="text" class="jumble-input" id="jumbleInput" placeholder="Your answer...">
                <div style="display:flex; gap:1rem; justify-content:center;">
                    <button class="btn" id="checkJumble">Check</button>
                    <button class="btn btn--outline" id="newJumble">New Word</button>
                </div>
                <p class="jumble-feedback" id="jumbleFeedback"></p>
            </div>
        </section>

        <!-- Inspirational Quote -->
        <div class="quote-box fade-up" style="text-align:center; font-style:italic; color:var(--text-light); padding:2rem;">
            <p style="font-size:1.2rem;" id="quoteText"></p>
            <small style="display:block; margin-top:0.5rem;" id="quoteAuthor"></small>
        </div>

        <!-- Contact (secret chat entrance) -->
        <section id="contact" class="fade-up" style="text-align:center; padding:3rem 0;">
            <h2>📞 Contact Us</h2>
            <div class="card" style="max-width:500px; margin:0 auto;">
                <p>📧 <a href="mailto:support@campusfify.com" style="color:var(--primary);">support@campusfify.com</a></p>
                <p>📞 <a href="tel:+919999999999" style="color:var(--primary);">+91 99999 99999</a></p>
                <p>🏢 New Delhi, India</p>
            </div>
        </section>
    </main>

    <footer>
        <p>📚 LitMaster · Your interactive English study companion for 11th grade.</p>
        <a href="#contact" class="btn btn--contact footer-btn">📞 Contact Us</a>
    </footer>

    <canvas id="confettiCanvas"></canvas>

    <script>
        window.isLoggedIn = <%= user ? 'true' : 'false' %>;

        // ---------- DARK MODE ----------
        const darkToggle = document.getElementById('darkToggle');
        const storedDark = localStorage.getItem('darkMode') === 'true';
        if (storedDark) document.body.classList.add('dark');
        darkToggle.textContent = storedDark ? '☀️' : '🌙';
        darkToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark');
            const isDark = document.body.classList.contains('dark');
            localStorage.setItem('darkMode', isDark);
            darkToggle.textContent = isDark ? '☀️' : '🌙';
        });

        // ---------- SECRET CHAT ENTRANCE ----------
        document.querySelectorAll('.contact-link, .btn--contact, .footer-btn').forEach(btn => {
            btn.addEventListener('click', e => {
                e.preventDefault();
                window.isLoggedIn ? window.location.href = '/chat' : window.location.href = '/login';
            });
        });

        // ---------- SCROLL REVEAL ----------
        const revealElements = document.querySelectorAll('.fade-up');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('visible');
            });
        }, { threshold: 0.15 });
        revealElements.forEach(el => observer.observe(el));

        // ---------- TYPING TIP ----------
        const tips = [
            { tip: "Always read comprehension questions before the passage.", category: "exam strategy" },
            { tip: "Use 'few' for countable nouns, 'little' for uncountable ones.", category: "grammar" },
            { tip: "Formal letters need sender's address, date, and subject line.", category: "writing" },
            { tip: "The poem 'A Photograph' often appears with themes of loss and memory.", category: "literature" },
            { tip: "Spend 5 minutes planning your essay – a quick mind map prevents panic.", category: "time management" },
            { tip: "Notice writing is a guaranteed 4‑mark question; practice 2 formats a week.", category: "high‑probability" }
        ];
        let tipIdx = Math.floor(Math.random() * tips.length);
        let charIdx = 0;
        const tipText = document.getElementById('typingTip');
        const tipCat = document.getElementById('tipCategory');

        function typeTip() {
            const current = tips[tipIdx];
            tipCat.textContent = current.category;
            tipText.textContent = '';
            charIdx = 0;
            const interval = setInterval(() => {
                if (charIdx < current.tip.length) {
                    tipText.textContent += current.tip[charIdx];
                    charIdx++;
                } else {
                    clearInterval(interval);
                    setTimeout(() => {
                        tipIdx = (tipIdx + 1) % tips.length;
                        typeTip();
                    }, 4000);
                }
            }, 40);
        }
        typeTip();

        // ---------- FUN FACT (rotates on click / every 10 sec) ----------
        const facts = [
            { fact: "The oldest known written language is Sumerian, dating back to 3500 BC.", icon: "🏛️", source: "History of Writing" },
            { fact: "William Shakespeare invented over 1,700 words, including 'bedroom' and 'lonely'.", icon: "🎭", source: "Shakespeare Lexicon" },
            { fact: "The longest word in English has 189,819 letters and takes over three hours to pronounce.", icon: "📖", source: "Guinness World Records" },
            { fact: "English is the official language of 67 countries and 27 non‑sovereign entities.", icon: "🌍", source: "Ethnologue" },
            { fact: "The first English dictionary was written in 1755 by Samuel Johnson.", icon: "📚", source: "Johnson's Dictionary" },
            { fact: "The dot over the letter 'i' is called a 'tittle'.", icon: "🔤", source: "Typography Trivia" },
        ];
        let currentFactIdx = Math.floor(Math.random() * facts.length);
        const factCard = document.getElementById('funFactCard');
        const factIcon = document.getElementById('factIcon');
        const factText = document.getElementById('factText');
        const factSource = document.getElementById('factSource');

        function showFact() {
            const fact = facts[currentFactIdx];
            factIcon.textContent = fact.icon;
            factText.textContent = fact.fact;
            factSource.textContent = `— ${fact.source}`;
            // Add subtle animation
            factCard.style.transform = 'scale(0.98)';
            setTimeout(() => { factCard.style.transform = ''; }, 150);
        }
        showFact();
        factCard.addEventListener('click', () => {
            currentFactIdx = (currentFactIdx + 1) % facts.length;
            showFact();
        });
        setInterval(() => {
            currentFactIdx = (currentFactIdx + 1) % facts.length;
            showFact();
        }, 10000);

        // ---------- WORD JUMBLE ----------
        const jumbleWords = [
            { word: "LITERATURE", hint: "The body of written works." },
            { word: "GRAMMAR", hint: "Rules of a language." },
            { word: "VOCABULARY", hint: "Collection of words." },
            { word: "SYNTAX", hint: "Sentence structure." },
            { word: "METAPHOR", hint: "Figure of speech." },
            { word: "ALLITERATION", hint: "Repetition of initial sounds." },
        ];
        let currentWordObj = jumbleWords[Math.floor(Math.random() * jumbleWords.length)];
        const scrambledEl = document.getElementById('scrambledWord');
        const jumbleInput = document.getElementById('jumbleInput');
        const jumbleFeedback = document.getElementById('jumbleFeedback');
        const checkBtn = document.getElementById('checkJumble');
        const newBtn = document.getElementById('newJumble');

        function scrambleWord(word) {
            const arr = word.split('');
            for (let i = arr.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [arr[i], arr[j]] = [arr[j], arr[i]];
            }
            // Ensure it's not identical to original
            if (arr.join('') === word) return scrambleWord(word);
            return arr.join('');
        }

        function loadJumble() {
            currentWordObj = jumbleWords[Math.floor(Math.random() * jumbleWords.length)];
            scrambledEl.textContent = scrambleWord(currentWordObj.word);
            jumbleInput.value = '';
            jumbleFeedback.textContent = '';
        }
        loadJumble();

        checkBtn.addEventListener('click', () => {
            const answer = jumbleInput.value.trim().toUpperCase();
            if (answer === currentWordObj.word) {
                jumbleFeedback.innerHTML = '✅ Correct! Great job!';
                jumbleFeedback.style.color = 'var(--green)';
                // Load new word after a short delay
                setTimeout(loadJumble, 2000);
            } else {
                jumbleFeedback.innerHTML = `❌ Try again! Hint: ${currentWordObj.hint}`;
                jumbleFeedback.style.color = 'var(--red)';
            }
        });
        newBtn.addEventListener('click', loadJumble);

        // ---------- QUOTE ----------
        const quotes = [
            { text: "The beautiful thing about learning is nobody can take it away from you.", author: "B.B. King" },
            { text: "Education is the passport to the future.", author: "Malcolm X" },
            { text: "The expert in anything was once a beginner.", author: "Helen Hayes" }
        ];
        const quote = quotes[Math.floor(Math.random() * quotes.length)];
        document.getElementById('quoteText').textContent = `“${quote.text}”`;
        document.getElementById('quoteAuthor').textContent = `— ${quote.author}`;

        // ---------- CONFETTI ----------
        const canvas = document.getElementById('confettiCanvas');
        const ctx = canvas.getContext('2d');
        let confettiPieces = [], running = false, raf = null;
        function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
        window.addEventListener('resize', resize);
        resize();

        class Confetti {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = -20;
                this.w = Math.random() * 10 + 6;
                this.h = Math.random() * 6 + 4;
                this.color = `hsl(${Math.random() * 360}, 90%, 70%)`;
                this.vy = Math.random() * 5 + 4;
                this.vx = (Math.random() - 0.5) * 4;
                this.rot = 0; this.rv = (Math.random() - 0.5) * 0.2;
                this.opacity = 1;
            }
            update() {
                this.vy += 0.08; this.vx *= 0.99; this.vy *= 0.99;
                this.x += this.vx; this.y += this.vy; this.rot += this.rv;
                if (this.y > canvas.height + 20) this.opacity = 0;
                if (this.opacity > 0 && this.y > canvas.height * 0.7)
                    this.opacity = Math.max(0, 1 - (this.y - canvas.height * 0.7) / (canvas.height * 0.3));
            }
            draw() {
                ctx.save(); ctx.globalAlpha = this.opacity; ctx.translate(this.x, this.y); ctx.rotate(this.rot);
                ctx.fillStyle = this.color; ctx.fillRect(-this.w/2, -this.h/2, this.w, this.h); ctx.restore();
            }
        }
        function launchConfetti(count = 200) {
            confettiPieces = Array.from({length: count}, () => new Confetti());
            running = true; canvas.classList.add('active');
            if (raf) cancelAnimationFrame(raf); animateConfetti();
            setTimeout(() => {
                running = false; if (raf) cancelAnimationFrame(raf);
                let fade = 1;
                const fadeInterval = setInterval(() => {
                    fade -= 0.04;
                    if (fade <= 0) { clearInterval(fadeInterval); canvas.classList.remove('active'); ctx.clearRect(0,0,canvas.width,canvas.height); }
                    else { ctx.clearRect(0,0,canvas.width,canvas.height); confettiPieces.forEach(p => { p.opacity *= 0.97; p.draw(); }); }
                }, 30);
            }, 6000);
        }
        function animateConfetti() {
            if (!running) return;
            ctx.clearRect(0,0,canvas.width,canvas.height);
            let alive = false;
            confettiPieces.forEach(p => { p.update(); if (p.opacity > 0.01) alive = true; p.draw(); });
            if (alive) raf = requestAnimationFrame(animateConfetti);
            else { canvas.classList.remove('active'); ctx.clearRect(0,0,canvas.width,canvas.height); }
        }

        // ===== QUIZ ENGINE (unchanged) =====
        let questions = [], currentIndex = 0, score = 0, xp = 0, streak = 0, highestStreak = 0;
        let answered = false, totalAttempted = 0, total = 0;
        const quizInner = document.getElementById('quizInner');

        async function fetchRandomQuestions(count) {
            try {
                const res = await fetch('/api/questions/random?count=' + count);
                const data = await res.json();
                return (data.success && data.questions) ? data.questions : [];
            } catch(e) { return []; }
        }

        function renderQuiz() {
            if (currentIndex >= total) {
                const percent = totalAttempted > 0 ? Math.round((score / totalAttempted) * 100) : 0;
                const grade = percent >= 80 ? '🌟 Amazing!' : percent >= 50 ? '💪 Nice try!' : '📚 Keep learning!';
                const emoji = percent >= 80 ? '🏆' : percent >= 50 ? '🎉' : '📖';
                const shareText = `I scored ${score}/${totalAttempted} (${percent}%) on LitMaster! 🏆 Try to beat me!`;

                if (percent >= 50) setTimeout(() => launchConfetti(220), 200);

                quizInner.innerHTML = `
                    <div class="quiz-result">
                        <span style="font-size:3rem;">${emoji}</span>
                        <h3>Quiz Complete!</h3>
                        <p style="color:var(--text-light);">${grade}</p>
                        <p style="color:var(--text-light);">You got <strong>${score}</strong> out of <strong>${totalAttempted}</strong> correct (${percent}%)<br>
                        ⭐ XP: ${xp}  ${streak > 0 ? ' | 🔥 Best Streak: ' + highestStreak : ''}</p>
                        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:1rem;">
                            <button class="btn" id="restartQuiz">🔄 New Round</button>
                            <button class="btn btn--outline" id="shareScore">📋 Copy Score</button>
                        </div>
                    </div>
                `;
                document.getElementById('restartQuiz').addEventListener('click', startNewQuiz);
                document.getElementById('shareScore').addEventListener('click', () => navigator.clipboard.writeText(shareText).then(() => alert('Score copied!')));
                return;
            }

            const q = questions[currentIndex];
            const isLast = currentIndex === total - 1;
            const optionsHtml = q.opts.map((opt, idx) => `
                <div class="option" data-optindex="${idx}">
                    <div class="circle"></div>
                    <label>${String.fromCharCode(65 + idx)}. ${opt}</label>
                </div>
            `).join('');
            const progress = ((currentIndex) / total) * 100;

            quizInner.innerHTML = `
                <div class="quiz-progress">
                    <span>Question ${currentIndex+1}/${total}</span>
                    <span class="badge">🏆 ${score}</span>
                    <span class="badge xp-badge">⭐ ${xp} XP</span>
                    ${streak > 0 ? `<span class="streak-fire">🔥${streak}</span>` : ''}
                </div>
                <div class="progress-bar"><div class="progress-fill" style="width:${progress}%;"></div></div>
                <div class="question-text">${q.q}</div>
                <div class="options" id="optionsContainer">${optionsHtml}</div>
                <div class="quiz-actions">
                    <div class="feedback" id="feedbackMsg">Select an option or click "Show Answer"</div>
                    <div style="display:flex; gap:0.8rem; flex-wrap:wrap;">
                        <button class="btn btn--outline" id="showAnswerBtn">👀 Show Answer</button>
                        <button class="btn" id="nextBtn" disabled>${isLast ? 'Finish' : 'Next →'}</button>
                    </div>
                </div>
            `;

            const nextBtn = document.getElementById('nextBtn');
            const showAnswerBtn = document.getElementById('showAnswerBtn');
            const feedback = document.getElementById('feedbackMsg');
            const options = document.querySelectorAll('.option');
            let selectedIdx = null;

            options.forEach(opt => {
                opt.addEventListener('click', () => {
                    if (opt.classList.contains('disabled') || answered) return;
                    options.forEach(o => o.classList.remove('selected'));
                    opt.classList.add('selected');
                    selectedIdx = parseInt(opt.dataset.optindex);
                    nextBtn.disabled = false;
                    feedback.textContent = 'Ready! Click Next to check.';
                    feedback.className = 'feedback';
                });
            });

            function handleAnswer() {
                if (answered || selectedIdx === null) return;
                answered = true;
                const correctIdx = q.ans;
                options.forEach((opt, idx) => {
                    opt.classList.add('disabled');
                    if (idx === correctIdx) opt.classList.add('correct');
                    else if (idx === selectedIdx && idx !== correctIdx) opt.classList.add('wrong');
                });

                if (selectedIdx === correctIdx) {
                    score++; xp += 10; streak++;
                    if (streak > highestStreak) highestStreak = streak;
                    feedback.innerHTML = `✅ Correct! <span style="display:block;font-size:0.9rem;margin-top:0.2rem;">${q.fact}</span>`;
                    feedback.className = 'feedback correct';
                    if (streak >= 3) setTimeout(() => launchConfetti(120), 100);
                } else {
                    streak = 0;
                    feedback.innerHTML = `❌ Incorrect. <span style="display:block;font-size:0.9rem;margin-top:0.2rem;">${q.fact}</span>`;
                    feedback.className = 'feedback wrong';
                }
                totalAttempted++;
                nextBtn.textContent = isLast ? 'See Results' : 'Next →';
                document.querySelector('.badge').textContent = '🏆 ' + score;
                document.querySelector('.xp-badge').textContent = '⭐ ' + xp + ' XP';
                const streakEl = document.querySelector('.streak-fire');
                if (streakEl) streakEl.textContent = streak > 0 ? '🔥' + streak : '';
                nextBtn.onclick = () => { currentIndex = isLast ? total : currentIndex + 1; answered = false; selectedIdx = null; renderQuiz(); };
            }

            nextBtn.addEventListener('click', handleAnswer);
            showAnswerBtn.addEventListener('click', () => {
                if (answered) return;
                answered = true;
                const correctIdx = q.ans;
                options.forEach((opt, idx) => {
                    opt.classList.add('disabled');
                    if (idx === correctIdx) opt.classList.add('correct');
                });
                feedback.innerHTML = `👀 Answer shown: <span style="display:block;font-size:0.9rem;margin-top:0.2rem;">${q.fact}</span>`;
                feedback.className = 'feedback';
                totalAttempted++;
                nextBtn.disabled = false;
                nextBtn.textContent = isLast ? 'See Results' : 'Next →';
                streak = 0;
                const streakEl = document.querySelector('.streak-fire');
                if (streakEl) streakEl.textContent = '';
                nextBtn.onclick = () => { currentIndex = isLast ? total : currentIndex + 1; answered = false; selectedIdx = null; renderQuiz(); };
            });
        }

        async function startNewQuiz() {
            // Show shimmer while loading
            quizInner.innerHTML = `<div style="display:flex; flex-direction:column; gap:1rem;">
                <div class="shimmer" style="height:2rem; width:60%;"></div>
                <div class="shimmer" style="height:1.5rem; width:80%;"></div>
                <div class="shimmer" style="height:3rem; width:100%;"></div>
                <div class="shimmer" style="height:3rem; width:100%;"></div>
            </div>`;
            const fetched = await fetchRandomQuestions(10);
            if (!fetched.length) {
                quizInner.innerHTML = '<div class="quiz-result"><h3>❌ No questions yet</h3><p>Try again later!</p></div>';
                return;
            }
            questions = fetched; currentIndex = 0; score = 0; xp = 0; streak = 0; highestStreak = 0;
            answered = false; totalAttempted = 0; total = questions.length;
            renderQuiz();
        }
        startNewQuiz();

        // ---------- NAVIGATION ----------
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('.nav a[data-section]');
        function changeActiveLink() {
            let index = sections.length;
            while (--index && window.scrollY + 120 < sections[index].offsetTop) {}
            navLinks.forEach(link => link.classList.remove('active'));
            if (navLinks[index]) navLinks[index].classList.add('active');
        }
        changeActiveLink();
        window.addEventListener('scroll', changeActiveLink, { passive: true });
        navLinks.forEach(link => {
            link.addEventListener('click', e => {
                e.preventDefault();
                const target = document.getElementById(link.getAttribute('data-section'));
                if (target) target.scrollIntoView({ behavior: 'smooth' });
            });
        });
    </script>
</body>
</html>