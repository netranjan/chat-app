<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Campusfify · Culture & Heritage</title>
    
    <!-- No-cache headers to prevent back button access -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    
    <style>
        /* ----- BYJU’S inspired color palette ----- */
        :root {
            --cf-white: #ffffff;
            --cf-off-white: #f8f9fc;
            --cf-orange-400: #ff8c1a;
            --cf-orange-500: #f58220;
            --cf-orange-600: #e06b10;
            --cf-blue-400: #2b7be4;
            --cf-blue-500: #1a73e8;
            --cf-blue-600: #1558b0;
            --cf-gray-100: #f1f3f6;
            --cf-gray-200: #e2e6ee;
            --cf-gray-400: #8e96a8;
            --cf-gray-600: #4a5168;
            --cf-gray-800: #1e2638;
            --cf-shadow-sm: 0 4px 12px rgba(0, 0, 0, 0.04);
            --cf-shadow-md: 0 8px 28px rgba(0, 0, 0, 0.08);
            --cf-shadow-lg: 0 16px 48px rgba(0, 0, 0, 0.10);
            --cf-radius-card: 24px;
            --cf-radius-btn: 60px;
            --cf-transition: 0.2s ease-in-out;
            --cf-font: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--cf-font);
            background: var(--cf-off-white);
            color: var(--cf-gray-800);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
        }

        .cf-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        .cf-text-center {
            text-align: center;
        }
        .cf-mt-2 {
            margin-top: 1.6rem;
        }
        .cf-hidden {
            display: none !important;
        }

        .cf-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--cf-orange-500);
            color: white;
            font-weight: 600;
            font-size: 1rem;
            padding: 0.75rem 1.8rem;
            border: none;
            border-radius: var(--cf-radius-btn);
            cursor: pointer;
            text-decoration: none;
            transition: background var(--cf-transition), transform 0.1s;
            min-height: 54px;
            min-width: 160px;
            letter-spacing: 0.3px;
            box-shadow: 0 4px 12px rgba(245, 130, 32, 0.3);
        }
        .cf-btn:hover {
            background: var(--cf-orange-600);
            transform: translateY(-2px);
        }
        .cf-btn:active {
            transform: translateY(0);
        }
        .cf-btn--outline {
            background: transparent;
            color: var(--cf-orange-500);
            box-shadow: 0 0 0 2px var(--cf-orange-400);
            min-width: 120px;
        }
        .cf-btn--outline:hover {
            background: #fff5eb;
            color: var(--cf-orange-600);
            box-shadow: 0 0 0 2px var(--cf-orange-500);
        }
        .cf-btn--small {
            min-height: 44px;
            min-width: 120px;
            padding: 0.5rem 1.4rem;
            font-size: 0.95rem;
        }
        .cf-btn--blue {
            background: var(--cf-blue-500);
            box-shadow: 0 4px 12px rgba(26, 115, 232, 0.25);
        }
        .cf-btn--blue:hover {
            background: var(--cf-blue-600);
        }
        .cf-btn:disabled {
            opacity: 0.5;
            pointer-events: none;
        }
        .cf-btn--skip {
            background: var(--cf-gray-400);
            box-shadow: none;
            min-width: 100px;
        }
        .cf-btn--skip:hover {
            background: var(--cf-gray-600);
        }
        .cf-btn--contact {
            background: #28a745;
            box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        }
        .cf-btn--contact:hover {
            background: #218838;
        }

        .cf-card {
            background: var(--cf-white);
            border-radius: var(--cf-radius-card);
            box-shadow: var(--cf-shadow-sm);
            padding: 1.8rem 1.6rem;
            transition: box-shadow var(--cf-transition);
            border: 1px solid rgba(0, 0, 0, 0.02);
        }
        .cf-card:hover {
            box-shadow: var(--cf-shadow-md);
        }

        .cf-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.03);
            padding: 0.6rem 0;
        }
        .cf-header-inner {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 0.8rem 1.2rem;
        }
        .cf-logo {
            font-weight: 700;
            font-size: 1.7rem;
            letter-spacing: -0.5px;
            color: var(--cf-orange-500);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .cf-logo span {
            color: var(--cf-gray-600);
            font-weight: 400;
            font-size: 0.9rem;
            letter-spacing: 0.3px;
            margin-left: 4px;
        }
        .cf-nav-wrapper {
            display: flex;
            align-items: center;
            gap: 1.2rem;
        }
        .cf-nav {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 1.2rem 2rem;
            font-weight: 500;
        }
        .cf-nav a {
            color: var(--cf-gray-600);
            text-decoration: none;
            font-size: 1rem;
            padding: 0.4rem 0;
            border-bottom: 2px solid transparent;
            transition: color var(--cf-transition), border-color var(--cf-transition);
        }
        .cf-nav a:hover,
        .cf-nav a:focus {
            color: var(--cf-orange-500);
            border-bottom-color: var(--cf-orange-400);
        }
        .cf-nav a.cf-active-link {
            color: var(--cf-orange-600);
            border-bottom-color: var(--cf-orange-500);
        }
        .cf-nav-right {
            display: flex;
            align-items: center;
            gap: 0.8rem 1.6rem;
            margin-left: auto;
            flex-wrap: wrap;
        }
        .cf-contact-link {
            font-weight: 600;
            color: var(--cf-white);
            text-decoration: none;
            padding: 0.4rem 1.2rem;
            border-radius: 40px;
            background: #28a745;
            transition: background var(--cf-transition);
        }
        .cf-contact-link:hover {
            background: #218838;
        }
        .cf-hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            background: transparent;
            border: none;
            cursor: pointer;
            padding: 0.3rem;
            border-radius: 8px;
        }
        .cf-hamburger span {
            display: block;
            width: 28px;
            height: 3px;
            background: var(--cf-gray-800);
            border-radius: 4px;
            transition: all 0.25s ease;
        }
        .cf-hamburger.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 5px);
        }
        .cf-hamburger.active span:nth-child(2) {
            opacity: 0;
        }
        .cf-hamburger.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -5px);
        }

        .cf-hero {
            padding: 3.2rem 0 3.8rem;
            background: linear-gradient(135deg, #fefaf5 0%, #fff8f0 100%);
            border-bottom: 1px solid var(--cf-gray-200);
        }
        .cf-hero-content {
            max-width: 780px;
            margin: 0 auto;
            text-align: center;
        }
        .cf-hero h1 {
            font-size: clamp(2.2rem, 8vw, 3.8rem);
            font-weight: 700;
            letter-spacing: -1px;
            line-height: 1.15;
            color: var(--cf-orange-600);
            margin-bottom: 0.6rem;
        }
        .cf-hero p {
            font-size: 1.2rem;
            color: var(--cf-gray-600);
            max-width: 560px;
            margin: 0 auto 1.6rem;
        }

        .cf-quiz {
            padding: 3.6rem 0 4.6rem;
            background: var(--cf-white);
        }
        .cf-quiz h2 {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--cf-orange-600);
            margin-bottom: 0.4rem;
        }
        .cf-quiz-sub {
            color: var(--cf-gray-600);
            margin-bottom: 2rem;
        }

        .cf-quiz-card {
            max-width: 820px;
            margin: 0 auto;
            background: var(--cf-white);
            border-radius: var(--cf-radius-card);
            box-shadow: var(--cf-shadow-md);
            padding: 2.2rem 2rem;
            border: 1px solid rgba(0, 0, 0, 0.02);
            position: relative;
            overflow: hidden;
        }
        .cf-quiz-progress {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.2rem;
            font-weight: 500;
            color: var(--cf-gray-600);
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        .cf-badge {
            background: var(--cf-orange-400);
            color: white;
            padding: 0.2rem 1rem;
            border-radius: 40px;
            font-size: 0.8rem;
        }
        .cf-progress-bar {
            width: 100%;
            height: 6px;
            background: var(--cf-gray-200);
            border-radius: 10px;
            margin: 0.6rem 0 1.2rem;
            overflow: hidden;
        }
        .cf-progress-fill {
            height: 100%;
            background: var(--cf-orange-500);
            border-radius: 10px;
            transition: width 0.3s ease;
            width: 0%;
        }
        .cf-question-text {
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 1.8rem;
            color: var(--cf-gray-800);
        }
        .cf-options {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
            margin-bottom: 1.2rem;
        }
        .cf-option {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.9rem 1.4rem;
            background: var(--cf-off-white);
            border-radius: 60px;
            border: 2px solid transparent;
            cursor: pointer;
            transition: background var(--cf-transition), border-color var(--cf-transition);
            font-size: 1rem;
            user-select: none;
        }
        .cf-option:hover:not(.cf-disabled) {
            background: #f0f4ff;
            border-color: var(--cf-blue-400);
        }
        .cf-option input[type="radio"] {
            appearance: none;
            width: 20px;
            height: 20px;
            border: 2px solid var(--cf-gray-400);
            border-radius: 50%;
            flex-shrink: 0;
            transition: border 0.15s, background 0.15s;
            position: relative;
            cursor: pointer;
            margin: 0;
        }
        .cf-option input[type="radio"]:checked {
            border-color: var(--cf-blue-500);
            background: var(--cf-blue-500);
        }
        .cf-option input[type="radio"]:checked::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: white;
        }
        .cf-option label {
            flex: 1;
            cursor: pointer;
            font-weight: 450;
            margin: 0;
        }
        .cf-option.cf-correct {
            background: #e6f7e6;
            border-color: #28a745;
        }
        .cf-option.cf-correct input[type="radio"] {
            border-color: #28a745;
            background: #28a745;
        }
        .cf-option.cf-wrong {
            background: #fce8e8;
            border-color: #dc3545;
        }
        .cf-option.cf-wrong input[type="radio"] {
            border-color: #dc3545;
            background: #dc3545;
        }
        .cf-option.cf-disabled {
            pointer-events: none;
            opacity: 0.8;
        }

        .cf-quiz-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.8rem;
            margin-top: 0.8rem;
        }
        .cf-feedback {
            font-weight: 500;
            padding: 0.6rem 1.2rem;
            border-radius: 40px;
            background: var(--cf-gray-100);
            color: var(--cf-gray-600);
            flex: 1;
            min-width: 150px;
        }
        .cf-feedback.cf-correct-text {
            background: #d4edda;
            color: #155724;
        }
        .cf-feedback.cf-wrong-text {
            background: #f8d7da;
            color: #721c24;
        }
        .cf-quiz-result {
            text-align: center;
            padding: 1.6rem 0;
            position: relative;
            z-index: 2;
        }
        .cf-quiz-result h3 {
            font-size: 2rem;
            color: var(--cf-orange-600);
        }
        .cf-quiz-result p {
            font-size: 1.2rem;
            color: var(--cf-gray-600);
        }
        .cf-quiz-result .cf-result-emoji {
            font-size: 4rem;
            display: block;
            margin-bottom: 0.4rem;
        }
        .cf-quiz-result .cf-result-grade {
            font-size: 2rem;
            font-weight: 700;
            color: var(--cf-orange-500);
            margin: 0.4rem 0;
        }
        .cf-quiz-result .cf-result-stats {
            font-size: 1.1rem;
            color: var(--cf-gray-600);
            margin-bottom: 1.2rem;
        }

        .cf-footer {
            background: var(--cf-gray-800);
            color: rgba(255, 255, 255, 0.8);
            padding: 2.8rem 0 2.2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }
        .cf-footer-inner {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: 1.4rem;
            text-align: center;
        }
        .cf-footer-brand {
            font-weight: 700;
            font-size: 1.6rem;
            color: white;
            letter-spacing: -0.3px;
        }
        .cf-footer-brand small {
            font-weight: 400;
            font-size: 0.8rem;
            opacity: 0.6;
            display: block;
            margin-top: 4px;
        }
        .cf-footer-disclaimer {
            font-size: 0.9rem;
            opacity: 0.7;
            max-width: 400px;
        }
        .cf-footer .cf-footer-buttons {
            display: flex;
            gap: 0.8rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        /* ----- Confetti Canvas ----- */
        #confettiCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: 9999;
            display: none;
        }
        #confettiCanvas.active {
            display: block;
        }

        /* ----- Responsive ----- */
        @media (max-width: 768px) {
            .cf-header-inner {
                flex-wrap: nowrap;
            }
            .cf-hamburger {
                display: flex;
                order: 3;
            }
            .cf-nav-wrapper {
                order: 4;
                flex-basis: 100%;
                display: none;
                flex-direction: column;
                align-items: stretch;
                background: var(--cf-white);
                padding: 1rem 0;
                border-top: 1px solid var(--cf-gray-200);
                margin-top: 0.4rem;
            }
            .cf-nav-wrapper.open {
                display: flex;
            }
            .cf-nav {
                flex-direction: column;
                align-items: stretch;
                gap: 0.8rem;
                width: 100%;
            }
            .cf-nav a {
                padding: 0.6rem 0.8rem;
                border-bottom: none;
                border-left: 4px solid transparent;
            }
            .cf-nav a:hover {
                border-left-color: var(--cf-orange-500);
            }
            .cf-nav-right {
                margin-left: 0;
                justify-content: flex-start;
                padding-top: 0.6rem;
                border-top: 1px solid var(--cf-gray-200);
                margin-top: 0.4rem;
                flex-wrap: wrap;
            }
            .cf-hero h1 {
                font-size: 2.2rem;
            }
            .cf-hero p {
                font-size: 1rem;
            }
            .cf-quiz-card {
                padding: 1.6rem;
            }
            .cf-question-text {
                font-size: 1.2rem;
            }
            .cf-option {
                padding: 0.7rem 1rem;
            }
            .cf-quiz-actions {
                flex-direction: column;
                align-items: stretch;
            }
            .cf-quiz-actions .cf-btn {
                width: 100%;
                justify-content: center;
            }
            .cf-feedback {
                min-width: auto;
            }
            .cf-footer-inner {
                flex-direction: column;
                text-align: center;
            }
            .cf-footer .cf-footer-buttons {
                justify-content: center;
            }
        }

        @media (max-width: 480px) {
            .cf-container {
                padding: 0 16px;
            }
            .cf-btn {
                min-width: 120px;
                padding: 0.6rem 1.2rem;
                font-size: 0.95rem;
            }
            .cf-hero {
                padding: 2.4rem 0 2.8rem;
            }
            .cf-quiz-card {
                padding: 1.2rem;
            }
        }

        @media (min-width: 1024px) {
            .cf-card {
                padding: 2.4rem 2.2rem;
            }
        }

        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            border: 0;
        }
    </style>
</head>
<body>
    <!-- ====== HEADER ====== -->
    <header class="cf-header" role="banner" aria-label="Main navigation">
        <div class="cf-container cf-header-inner">
            <a href="/" class="cf-logo" aria-label="Campusfify home">
                Campusfify <span>Culture & Heritage</span>
            </a>
            <button class="cf-hamburger" id="hamburgerBtn" aria-label="Toggle navigation menu" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
            <div class="cf-nav-wrapper" id="navWrapper">
                <nav class="cf-nav" aria-label="Primary navigation">
                    <a href="#quiz" data-section="quiz" class="cf-active-link">Quiz</a>
                    <div class="cf-nav-right">
                        <a href="#contact" class="cf-contact-link">📞 Contact Us</a>
                    </div>
                </nav>
            </div>
        </div>
    </header>

    <!-- ====== HERO ====== -->
    <section class="cf-hero" aria-labelledby="hero-title">
        <div class="cf-container cf-hero-content">
            <h1 id="hero-title">Explore Culture & Heritage</h1>
            <p>Learn about festivals, traditions, clothing, and cuisine from across India, with a focus on Punjab and Maharashtra.</p>
        </div>
    </section>

    <!-- ====== QUIZ SECTION ====== -->
    <section class="cf-quiz" id="quiz" aria-labelledby="quiz-title">
        <div class="cf-container">
            <h2 id="quiz-title" class="cf-text-center">📚 Culture & Heritage Quiz</h2>
            <p class="cf-quiz-sub cf-text-center">10 random questions each round – test your knowledge of Indian culture.</p>
            <div class="cf-quiz-card" id="quizContainer" role="main" aria-live="polite">
                <div id="quizInner"></div>
            </div>
        </div>
    </section>

    <!-- ====== CONTACT SECTION ====== -->
    <section id="contact" class="cf-quiz" style="background: var(--cf-off-white); padding: 3rem 0 4rem;">
        <div class="cf-container">
            <h2 class="cf-text-center" style="font-size: 2.2rem; font-weight: 700; color: var(--cf-orange-600); margin-bottom: 0.4rem;">📞 Contact Us</h2>
            <p class="cf-text-center" style="color: var(--cf-gray-600); margin-bottom: 2rem;">Have questions? Reach out to us anytime.</p>
            <div style="max-width: 600px; margin: 0 auto; background: var(--cf-white); border-radius: var(--cf-radius-card); padding: 2rem; box-shadow: var(--cf-shadow-sm); text-align: center;">
                <p style="font-size: 1.1rem; color: var(--cf-gray-600); margin-bottom: 0.5rem;">📧 Email: <a href="mailto:support@campusfify.com" style="color: var(--cf-blue-500); text-decoration: none;">support@campusfify.com</a></p>
                <p style="font-size: 1.1rem; color: var(--cf-gray-600); margin-bottom: 0.5rem;">📞 Phone: <a href="tel:+919999999999" style="color: var(--cf-blue-500); text-decoration: none;">+91 99999 99999</a></p>
                <p style="font-size: 1.1rem; color: var(--cf-gray-600);">🏢 Office: New Delhi, India</p>
            </div>
        </div>
    </section>

    <!-- ====== CONFETTI CANVAS ====== -->
    <canvas id="confettiCanvas"></canvas>

    <!-- ====== FOOTER ====== -->
    <footer class="cf-footer" role="contentinfo">
        <div class="cf-container cf-footer-inner">
            <div class="cf-footer-brand">
                Campusfify
                <small>Celebrating India's diversity</small>
            </div>
            <p class="cf-footer-disclaimer">
                All content is for educational and cultural awareness purposes.
                Explore the heritage of Punjab and Maharashtra.
            </p>
            <div class="cf-footer-buttons">
                <a href="#contact" class="cf-btn cf-btn--contact cf-btn--small">
                    📞 Contact Us
                </a>
            </div>
        </div>
    </footer>

    <script>
        (function() {
            'use strict';

            // ----- Prevent back button access -----
            window.addEventListener('pageshow', function(event) {
                if (event.persisted) {
                    window.location.reload();
                }
            });
            history.pushState(null, null, location.href);
            window.addEventListener('popstate', function() {
                history.pushState(null, null, location.href);
                window.location.replace('/');
            });

            // ----- Contact button redirects to login or chat -----
            document.querySelectorAll('.cf-contact-link, .cf-btn--contact').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    fetch('/messages', {
                        credentials: 'include'
                    }).then(function(response) {
                        if (response.status === 401) {
                            window.location.href = '/login';
                        } else {
                            window.location.href = '/chat';
                        }
                    }).catch(function() {
                        window.location.href = '/login';
                    });
                });
            });

            // ----- Confetti Engine -----
            const confettiCanvas = document.getElementById('confettiCanvas');
            const ctx = confettiCanvas.getContext('2d');
            let confettiPieces = [];
            let confettiRunning = false;
            let confettiRAF = null;

            function resizeConfettiCanvas() {
                confettiCanvas.width = window.innerWidth;
                confettiCanvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resizeConfettiCanvas);
            resizeConfettiCanvas();

            class ConfettiPiece {
                constructor() {
                    this.x = Math.random() * confettiCanvas.width;
                    this.y = -20;
                    this.w = Math.random() * 10 + 6;
                    this.h = Math.random() * 6 + 4;
                    this.color = `hsl(${Math.random() * 360}, 90%, 60%)`;
                    this.speedY = Math.random() * 5 + 4;
                    this.speedX = (Math.random() - 0.5) * 4;
                    this.rotation = 0;
                    this.rotSpeed = (Math.random() - 0.5) * 0.2;
                    this.opacity = 1;
                    this.friction = 0.99;
                    this.gravity = 0.08;
                    this.wind = (Math.random() - 0.5) * 0.06;
                }
                update() {
                    this.speedY += this.gravity;
                    this.speedX += this.wind;
                    this.speedY *= this.friction;
                    this.speedX *= this.friction;
                    this.x += this.speedX;
                    this.y += this.speedY;
                    this.rotation += this.rotSpeed;
                    if (this.y > confettiCanvas.height + 20) {
                        this.opacity = 0;
                    }
                    if (this.opacity > 0 && this.y > confettiCanvas.height * 0.7) {
                        this.opacity = Math.max(0, 1 - (this.y - confettiCanvas.height * 0.7) / (confettiCanvas.height * 0.3));
                    }
                }
                draw() {
                    ctx.save();
                    ctx.globalAlpha = this.opacity;
                    ctx.translate(this.x, this.y);
                    ctx.rotate(this.rotation);
                    ctx.fillStyle = this.color;
                    ctx.shadowColor = 'rgba(0,0,0,0.1)';
                    ctx.shadowBlur = 4;
                    ctx.fillRect(-this.w / 2, -this.h / 2, this.w, this.h);
                    ctx.restore();
                }
            }

            function launchConfetti(count) {
                count = count || 200;
                confettiPieces = [];
                for (var i = 0; i < count; i++) {
                    confettiPieces.push(new ConfettiPiece());
                }
                confettiRunning = true;
                confettiCanvas.classList.add('active');
                if (confettiRAF) cancelAnimationFrame(confettiRAF);
                animateConfetti();
                setTimeout(function() {
                    confettiRunning = false;
                    if (confettiRAF) cancelAnimationFrame(confettiRAF);
                    var fade = 1;
                    var fadeInterval = setInterval(function() {
                        fade -= 0.04;
                        if (fade <= 0) {
                            clearInterval(fadeInterval);
                            confettiCanvas.classList.remove('active');
                            ctx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
                        } else {
                            ctx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
                            confettiPieces.forEach(function(p) {
                                p.opacity *= 0.97;
                                p.draw();
                            });
                        }
                    }, 30);
                }, 6000);
            }

            function animateConfetti() {
                if (!confettiRunning) return;
                ctx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
                var alive = false;
                confettiPieces.forEach(function(p) {
                    p.update();
                    if (p.opacity > 0.01) alive = true;
                    p.draw();
                });
                if (alive) {
                    confettiRAF = requestAnimationFrame(animateConfetti);
                } else {
                    confettiCanvas.classList.remove('active');
                    ctx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
                }
            }

            // ----- Quiz state -----
            let questions = [];
            let currentIndex = 0;
            let score = 0;
            let answered = false;
            let totalAttempted = 0;
            let total = 0;

            const quizInner = document.getElementById('quizInner');

            // ----- Fetch questions from database API -----
            async function fetchRandomQuestions(count) {
                try {
                    const response = await fetch('/api/questions/random?count=' + count);
                    const data = await response.json();
                    if (data.success && data.questions && data.questions.length > 0) {
                        return data.questions;
                    }
                    return [];
                } catch (error) {
                    console.error('❌ Error fetching questions:', error);
                    return [];
                }
            }

            function renderQuiz() {
                if (currentIndex >= total) {
                    var percent = totalAttempted > 0 ? Math.round((score / totalAttempted) * 100) : 0;
                    var grade = percent >= 80 ? '🌟 Excellent!' : percent >= 50 ? '💪 Good job!' : '📚 Keep learning!';
                    var emoji = percent >= 80 ? '🏆' : percent >= 50 ? '🎉' : '📖';
                    var message = percent >= 80 ? 'You are a Culture Champion!' :
                        percent >= 50 ? 'Great effort! Keep exploring!' :
                        'Every expert was once a beginner. Keep going!';

                    if (percent >= 50) {
                        setTimeout(function() { launchConfetti(220); }, 200);
                    }

                    quizInner.innerHTML = `
                        <div class="cf-quiz-result">
                            <span class="cf-result-emoji">${emoji}</span>
                            <h3>🎉 Quiz Complete!</h3>
                            <div class="cf-result-grade">${grade}</div>
                            <p class="cf-result-stats">
                                You attempted <strong>${totalAttempted}</strong> questions and got
                                <strong style="color:var(--cf-orange-600);">${score}</strong> correct
                                (${percent}%)
                            </p>
                            <p style="font-size:1.1rem; color:var(--cf-gray-600); margin-bottom:1.2rem;">${message}</p>
                            <button class="cf-btn cf-btn--blue" id="restartQuiz">🔄 New 10 Questions</button>
                        </div>
                    `;
                    document.getElementById('restartQuiz').addEventListener('click', startNewQuiz);
                    return;
                }

                var q = questions[currentIndex];
                var isLast = currentIndex === total - 1;
                var optionsHtml = q.opts.map(function(opt, idx) {
                    return '<div class="cf-option" data-optindex="' + idx + '">' +
                        '<input type="radio" name="quizOption" id="opt_' + idx + '" value="' + idx + '">' +
                        '<label for="opt_' + idx + '">' + String.fromCharCode(65 + idx) + '. ' + opt + '</label>' +
                    '</div>';
                }).join('');

                var progress = ((currentIndex) / total) * 100;

                quizInner.innerHTML = `
                    <div class="cf-quiz-progress">
                        <span>Question ${currentIndex + 1} of ${total}</span>
                        <span class="cf-badge">🏆 Score: ${score}</span>
                    </div>
                    <div class="cf-progress-bar">
                        <div class="cf-progress-fill" style="width: ${progress}%;"></div>
                    </div>
                    <div class="cf-question-text">${q.q}</div>
                    <div class="cf-options" id="optionsContainer">
                        ${optionsHtml}
                    </div>
                    <div class="cf-quiz-actions">
                        <div class="cf-feedback" id="feedbackMsg">Select an option or skip</div>
                        <div style="display:flex; gap:0.8rem; flex-wrap:wrap;">
                            <button class="cf-btn cf-btn--skip" id="skipBtn">⏭️ Skip</button>
                            <button class="cf-btn" id="nextBtn" disabled>${isLast ? 'Finish' : 'Next →'}</button>
                        </div>
                    </div>
                `;

                var options = document.querySelectorAll('.cf-option');
                var nextBtn = document.getElementById('nextBtn');
                var skipBtn = document.getElementById('skipBtn');
                var feedback = document.getElementById('feedbackMsg');
                var radioInputs = document.querySelectorAll('input[name="quizOption"]');

                options.forEach(function(opt) {
                    opt.addEventListener('click', function(e) {
                        if (this.classList.contains('cf-disabled')) return;
                        var radio = this.querySelector('input[type="radio"]');
                        if (radio) {
                            radio.checked = true;
                            var evt = new Event('change', { bubbles: true });
                            radio.dispatchEvent(evt);
                        }
                    });
                    var label = opt.querySelector('label');
                    if (label) {
                        label.addEventListener('click', function(e) {
                            e.stopPropagation();
                        });
                    }
                });

                radioInputs.forEach(function(radio) {
                    radio.addEventListener('change', function() {
                        if (answered) return;
                        var checked = document.querySelector('input[name="quizOption"]:checked');
                        if (checked) {
                            nextBtn.disabled = false;
                            feedback.textContent = 'You selected an option. Click Next to check.';
                            feedback.className = 'cf-feedback';
                        } else {
                            nextBtn.disabled = true;
                            feedback.textContent = 'Select an option or skip';
                            feedback.className = 'cf-feedback';
                        }
                    });
                });

                nextBtn.addEventListener('click', function() {
                    if (answered) return;
                    var selected = document.querySelector('input[name="quizOption"]:checked');
                    if (!selected) return;
                    var selectedIdx = parseInt(selected.value);
                    var correctIdx = q.ans;
                    var allOpts = document.querySelectorAll('.cf-option');

                    allOpts.forEach(function(opt) {
                        opt.classList.add('cf-disabled');
                        var r = opt.querySelector('input[type="radio"]');
                        if (r) r.disabled = true;
                    });

                    allOpts.forEach(function(opt, idx) {
                        if (idx === correctIdx) {
                            opt.classList.add('cf-correct');
                        } else if (idx === selectedIdx && idx !== correctIdx) {
                            opt.classList.add('cf-wrong');
                        }
                    });

                    if (selectedIdx === correctIdx) {
                        score++;
                        feedback.innerHTML =
                            '✅ Correct! <span style="font-weight:normal; display:block; font-size:0.9rem; margin-top:0.2rem;">' + q.fact + '</span>';
                        feedback.className = 'cf-feedback cf-correct-text';
                    } else {
                        feedback.innerHTML =
                            '❌ Incorrect. <span style="font-weight:normal; display:block; font-size:0.9rem; margin-top:0.2rem;">' + q.fact + '</span>';
                        feedback.className = 'cf-feedback cf-wrong-text';
                    }

                    answered = true;
                    totalAttempted++;
                    nextBtn.textContent = isLast ? 'See Results' : 'Next →';
                    var badge = document.querySelector('.cf-badge');
                    if (badge) badge.textContent = '🏆 Score: ' + score;

                    nextBtn.onclick = function() {
                        if (currentIndex === total - 1) {
                            currentIndex = total;
                            renderQuiz();
                        } else {
                            currentIndex++;
                            answered = false;
                            renderQuiz();
                        }
                    };
                });

                skipBtn.addEventListener('click', function() {
                    if (answered) return;
                    var allOpts = document.querySelectorAll('.cf-option');
                    allOpts.forEach(function(opt) {
                        opt.classList.add('cf-disabled');
                        var r = opt.querySelector('input[type="radio"]');
                        if (r) r.disabled = true;
                        if (parseInt(opt.dataset.optindex) === q.ans) {
                            opt.classList.add('cf-correct');
                        }
                    });
                    feedback.innerHTML =
                        '⏭️ Skipped. <span style="font-weight:normal; display:block; font-size:0.9rem; margin-top:0.2rem;">' + q.fact + '</span>';
                    feedback.className = 'cf-feedback';
                    answered = true;
                    totalAttempted++;
                    nextBtn.disabled = false;
                    nextBtn.textContent = isLast ? 'See Results' : 'Next →';
                    var badge = document.querySelector('.cf-badge');
                    if (badge) badge.textContent = '🏆 Score: ' + score;
                    nextBtn.onclick = function() {
                        if (currentIndex === total - 1) {
                            currentIndex = total;
                            renderQuiz();
                        } else {
                            currentIndex++;
                            answered = false;
                            renderQuiz();
                        }
                    };
                });
            }

            async function startNewQuiz() {
                var count = 10;
                var fetchedQuestions = await fetchRandomQuestions(count);
                if (fetchedQuestions.length === 0) {
                    quizInner.innerHTML = `
                        <div class="cf-quiz-result">
                            <h3>❌ No Questions Available</h3>
                            <p>Please check back later or contact support.</p>
                        </div>
                    `;
                    return;
                }
                questions = fetchedQuestions;
                currentIndex = 0;
                score = 0;
                answered = false;
                totalAttempted = 0;
                total = questions.length;
                renderQuiz();
            }

            startNewQuiz();

            // ----- Mobile hamburger toggle -----
            var hamburger = document.getElementById('hamburgerBtn');
            var navWrapper = document.getElementById('navWrapper');
            hamburger.addEventListener('click', function() {
                var expanded = this.getAttribute('aria-expanded') === 'true' ? false : true;
                this.setAttribute('aria-expanded', expanded);
                navWrapper.classList.toggle('open');
                this.classList.toggle('active');
            });

            document.querySelectorAll('.cf-nav a').forEach(function(link) {
                link.addEventListener('click', function() {
                    if (window.innerWidth <= 768) {
                        hamburger.setAttribute('aria-expanded', 'false');
                        navWrapper.classList.remove('open');
                        hamburger.classList.remove('active');
                    }
                });
            });

            var navLinks = document.querySelectorAll('.cf-nav a[data-section]');
            function updateActiveNav() {
                var scrollY = window.scrollY + 120;
                var activeId = 'quiz';
                navLinks.forEach(function(link) {
                    var section = link.dataset.section;
                    link.classList.toggle('cf-active-link', section === activeId);
                });
            }

            window.addEventListener('scroll', updateActiveNav, { passive: true });
            window.addEventListener('resize', updateActiveNav, { passive: true });
            updateActiveNav();

            navLinks.forEach(function(link) {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    var sectionId = this.dataset.section;
                    var target = document.getElementById(sectionId);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        setTimeout(updateActiveNav, 100);
                    }
                });
            });

            console.log('Campusfify · Culture & Heritage Quiz loaded (questions from DB).');
        })();
    </script>
</body>
</html>